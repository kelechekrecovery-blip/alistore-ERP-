# AliStore root env template — self-hosted compose stack only (infra/docker-compose.yml).
# Copy to .env (git-ignored) and adjust. App-level templates live next to each app:
#   apps/api/.env.example            — API/worker local development
#   apps/api/.env.production.example — API/worker staging+production (Render/self-hosted)
#   apps/mobile/.env.production.example, apps/ios/.env.production.example — native reference
# Render staging/prod does NOT read this file: values are entered in the Render
# dashboard per infra/render.staging.yaml — see docs/OWNER-LAUNCH-CHECKLIST.md §2.

# MinIO (S3-compatible object storage) — console http://localhost:9001.
# MINIO_ROOT_USER/PASSWORD are the root credentials; MINIO_BUCKET is created by minio-init.
MINIO_ROOT_USER="alistore"
MINIO_ROOT_PASSWORD="change-me-please"
MINIO_BUCKET="alistore"

# Redis password — must match the password inside REDIS_URL in apps/api/.env.
REDIS_PASSWORD="change-me-please"

# Meilisearch master key — must match MEILI_API_KEY in apps/api/.env.
MEILI_API_KEY="change-me-search-key"

# Metabase (owner BI) — password for its own application database.
METABASE_DB_PASS="change-me-please"
