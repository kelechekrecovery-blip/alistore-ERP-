// ---------- CORE ----------
model Customer {
  id                   String                @id @default(cuid())
  phone                String                @unique // PII — маскировать младшим ролям
  name                 String
  consent              Boolean               @default(false) // маркетинг только при true
  segments             String[]
  ltv                  Int                   @default(0)
  identities           CustomerIdentity[]
  pushTokens           PushToken[]
  addresses            CustomerAddress[]
  preferences          CustomerPreferences?
  loyaltyEntries       LoyaltyEntry[]
  coupons              CustomerCoupon[]
  promotionRedemptions PromotionRedemption[]
  campaignRecipients   CampaignRecipient[]
  orders               Order[]
  tradeIns             TradeInDevice[]
  createdAt            DateTime              @default(now())
  // SupportTicket ссылается на customerId строкой (как WarrantyCase/DebtPlan) —
  // без @relation, чтобы очистка в тестах не каскадила через FK.
}

model CustomerAddress {
  id             String   @id @default(cuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title          String
  text           String
  comment        String?
  isPrimary      Boolean  @default(false)
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId, isPrimary])
}

model CustomerPreferences {
  customerId String   @id
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  push       Boolean  @default(true)
  whatsapp   Boolean  @default(true)
  service    Boolean  @default(true)
  promos     Boolean  @default(false)
  updatedAt  DateTime @updatedAt
}

model LoyaltyEntry {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  kind       String    @default("adjustment") // earn | redeem | refund_restore | refund_clawback | adjustment
  label      String
  amount     Int
  sourceRef  String?   @unique
  orderId    String?
  paymentId  String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([customerId, createdAt])
  @@index([orderId])
  @@index([paymentId])
}

model CustomerCoupon {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title      String
  code       String
  valueLabel String
  expiresAt  DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@unique([customerId, code])
  @@index([customerId, active])
}

model CustomerIdentity {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider    String
  subject     String
  email       String?
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, subject])
  @@index([customerId])
}

model PushToken {
  id         String     @id @default(cuid())
  token      String     @unique
  platform   String
  deviceId   String
  appScope   String     @default("anonymous") // anonymous | customer | staff
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staffId    String?
  staff      StaffUser? @relation(fields: [staffId], references: [id], onDelete: Cascade)
  enabled    Boolean    @default(true)
  lastSeenAt DateTime   @default(now())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([customerId, enabled])
  @@index([staffId, enabled])
  @@index([platform])
}

model Product {
  id                          String                       @id @default(cuid())
  sku                         String                       @unique
  barcode                     String?                      @unique
  variantGroup                String?
  name                        String
  price                       Int
  cost                        Int
  category                    String
  taxCode                     String                       @default("vat_standard")
  taxRateBps                  Int                          @default(1200)
  trackingMode                StockTrackingMode            @default(serialized)
  attrs                       Json
  archived                    Boolean                      @default(false) // soft-delete: НЕ удалять физически
  updatedAt                   DateTime                     @default(now()) @updatedAt
  units                       DeviceUnit[]
  movements                   InventoryMovement[]
  balances                    InventoryBalance[]
  quantityAllocations         OrderQuantityAllocation[]
  purchaseOrderItems          PurchaseOrderItem[]
  bundleComponents            ProductBundleComponent[]     @relation("BundleProduct")
  includedInBundles           ProductBundleComponent[]     @relation("BundleComponentProduct")
  bundleAllocations           OrderBundleAllocation[]
  consignmentItems            ConsignmentItem[]
  quantityConsignmentLots     QuantityConsignmentLot[]
  serviceParts                ServicePart[]
  valuationLayers             InventoryValuationLayer[]
  valuationIssues             InventoryValuationIssue[]
  valuationReversals          InventoryValuationReversal[]
  landedCostAllocations       LandedCostAllocation[]
  exchangeReplacementRequests ExchangeRequest[]            @relation("ExchangeReplacementProduct")

  @@index([category])
  @@index([variantGroup])
  @@index([archived])
  @@index([updatedAt])
}

model InventoryBalance {
  id                      String                    @id @default(cuid())
  product                 Product                   @relation(fields: [productId], references: [id])
  productId               String
  location                String
  onHand                  Int                       @default(0)
  reserved                Int                       @default(0)
  inventoryValue          Int                       @default(0) // value of on-hand stock at receipt cost
  updatedAt               DateTime                  @default(now()) @updatedAt
  allocations             OrderQuantityAllocation[]
  quantityConsignmentLots QuantityConsignmentLot[]
  serviceParts            ServicePart[]
  valuationLayers         InventoryValuationLayer[]

  @@unique([productId, location])
  @@index([location])
  @@index([updatedAt])
}

model ProductBundleComponent {
  id                 String  @id @default(cuid())
  bundleProduct      Product @relation("BundleProduct", fields: [bundleProductId], references: [id])
  bundleProductId    String
  componentProduct   Product @relation("BundleComponentProduct", fields: [componentProductId], references: [id])
  componentProductId String
  qty                Int

  @@unique([bundleProductId, componentProductId])
  @@index([componentProductId])
}

model ProductReview {
  id               String    @id @default(cuid())
  productId        String
  sku              String
  customerId       String
  customerName     String
  orderId          String
  rating           Int
  text             String?
  status           String    @default("pending")
  moderatedBy      String?
  moderatedAt      DateTime?
  moderationReason String?
  createdAt        DateTime  @default(now())

  @@unique([productId, customerId, orderId])
  @@index([productId])
  @@index([status, createdAt])
  @@index([customerId])
  @@index([orderId])
}

model DeviceUnit {
  id                          String                    @id @default(cuid())
  imei                        String                    @unique // один IMEI нельзя продать дважды
  product                     Product                   @relation(fields: [productId], references: [id])
  productId                   String
  status                      UnitStatus                @default(in_stock)
  grade                       Grade?
  location                    String
  acquisitionCost             Int?
  orderId                     String?
  updatedAt                   DateTime                  @default(now()) @updatedAt
  consignmentItem             ConsignmentItem?
  serviceReplacement          ServiceWorkOrder?         @relation("ServiceReplacementUnit")
  loanerProfile               LoanerDevice?
  valuationIssues             InventoryValuationIssue[]
  quarantineCases             InventoryQuarantineCase[]
  exchangeReturnRequests      ExchangeRequest[]         @relation("ExchangeReturnedUnit")
  exchangeReplacementRequests ExchangeRequest[]         @relation("ExchangeReplacementUnit")
  landedCostAllocations       LandedCostAllocation[]
  // повтор IMEI в trade-in + продаже → risk-флаг (проверка на сервере)

  @@index([productId])
  @@index([status])
  @@index([orderId])
  @@index([updatedAt])
}

model InventoryQuarantineCase {
  id                    String                          @id @default(cuid())
  unit                  DeviceUnit                      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  unitId                String
  return                Return                          @relation(fields: [returnId], references: [id], onDelete: Restrict)
  returnId              String
  sourceType            String
  reason                String
  unitCost              Int
  status                InventoryQuarantineStatus       @default(pending_diagnosis)
  diagnosis             InventoryQuarantineDiagnosis?
  disposition           InventoryQuarantineDisposition?
  notes                 String?
  createdBy             String
  diagnosedBy           String?
  disposedBy            String?
  diagnosedAt           DateTime?
  disposedAt            DateTime?
  dispositionApproval   Approval?                       @relation(fields: [dispositionApprovalId], references: [id], onDelete: Restrict)
  dispositionApprovalId String?                         @unique
  repairWorkOrder       ServiceWorkOrder?               @relation(fields: [repairWorkOrderId], references: [id], onDelete: Restrict)
  repairWorkOrderId     String?                         @unique
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt

  @@unique([sourceType, returnId, unitId])
  @@index([status, createdAt])
  @@index([unitId, status])
  @@index([returnId])
}

model StorePoint {
  id                 String              @id @default(cuid())
  code               String              @unique
  name               String
  address            String
  inventoryLocation  String              @unique
  hours              String
  pickupInstructions String?
  active             Boolean             @default(true)
  sortOrder          Int                 @default(100)
  createdBy          String
  idempotencyKey     String              @unique
  orders             Order[]
  commands           StorePointCommand[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([active, sortOrder])
}

model StorePointCommand {
  idempotencyKey String     @id
  storePoint     StorePoint @relation(fields: [storePointId], references: [id], onDelete: Cascade)
  storePointId   String
  fingerprint    String
  response       Json
  createdAt      DateTime   @default(now())

  @@index([storePointId, createdAt])
}

model PromotionCode {
  id                 String                @id @default(cuid())
  code               String                @unique
  name               String
  description        String?
  status             PromotionStatus       @default(draft)
  discountType       PromotionDiscountType
  discountValue      Int
  maxDiscount        Int?
  minimumSubtotal    Int                   @default(0)
  eligibleProductIds String[]
  eligibleCategories String[]
  startsAt           DateTime?
  endsAt             DateTime?
  totalLimit         Int?
  perCustomerLimit   Int?
  createdBy          String
  updatedBy          String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  redemptions        PromotionRedemption[]

  @@index([status, startsAt, endsAt])
  @@index([createdAt])
}

model PromotionRedemption {
  id             String        @id @default(cuid())
  promotion      PromotionCode @relation(fields: [promotionId], references: [id], onDelete: Restrict)
  promotionId    String
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerId     String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String        @unique
  discountAmount Int
  createdAt      DateTime      @default(now())

  @@index([promotionId, createdAt])
  @@index([promotionId, customerId, createdAt])
}

model StorefrontBlock {
  id          String                @id @default(cuid())
  type        StorefrontBlockType
  status      StorefrontBlockStatus @default(draft)
  device      StorefrontBlockDevice @default(all)
  position    Int
  title       String
  eyebrow     String?
  body        String?
  ctaLabel    String?
  ctaHref     String?
  imageUrl    String?
  tone        String                @default("dark")
  productIds  String[]
  startsAt    DateTime?
  endsAt      DateTime?
  publishedAt DateTime?
  createdBy   String
  updatedBy   String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([status, device, position])
  @@index([type, startsAt, endsAt])
}

model Order {
  id                       String                          @id @default(cuid())
  idempotencyKey           String?                         @unique
  isDemo                   Boolean                         @default(false)
  customer                 Customer                        @relation(fields: [customerId], references: [id])
  customerId               String
  status                   OrderStatus                     @default(draft)
  channel                  String // web | app | mobile | pos | telegram
  fulfillmentType          String                          @default("pickup") // pickup | courier | express | store
  paymentMode              String                          @default("prepaid") // prepaid | cod
  paymentModeExplicit      Boolean                         @default(false)
  idempotencyRequestHash   String?
  storePointId             String?
  storePoint               StorePoint?                     @relation(fields: [storePointId], references: [id], onDelete: Restrict)
  storePointCode           String?
  storePointName           String?
  storePointAddress        String?
  posShiftId               String?
  posShift                 CashShift?                      @relation(fields: [posShiftId], references: [id], onDelete: Restrict)
  pickupPoint              String?
  pickupAddress            String?
  fulfillmentLocation      String?
  deliveryAddress          String?
  deliverySlot             String?
  deliveryZoneId           String?
  deliveryZone             DeliveryZone?                   @relation(fields: [deliveryZoneId], references: [id])
  deliverySlotId           String?
  logisticsSlot            DeliverySlot?                   @relation(fields: [deliverySlotId], references: [id])
  courierId                String?
  courier                  StaffUser?                      @relation("OrderCourier", fields: [courierId], references: [id])
  courierRunId             String?
  courierRun               CourierRun?                     @relation(fields: [courierRunId], references: [id])
  pickupCode               String?
  subtotal                 Int                             @default(0)
  deliveryFee              Int                             @default(0)
  promoCode                String?
  promoDiscount            Int                             @default(0)
  promotionRedemption      PromotionRedemption?
  loyaltyRedeemed          Int                             @default(0)
  loyaltyEarned            Int                             @default(0)
  taxBaseAmount            Int                             @default(0)
  taxAmount                Int                             @default(0)
  total                    Int
  items                    OrderItem[]
  bundleAllocations        OrderBundleAllocation[]
  quantityAllocations      OrderQuantityAllocation[]
  consignmentSales         ConsignmentItem[]               @relation("ConsignmentSaleOrder")
  quantityConsignmentSales QuantityConsignmentAllocation[] @relation("QuantityConsignmentSaleOrder")
  payments                 Payment[]
  refunds                  Refund[]
  attribution              OrderAttribution?
  returns                  Return[]
  exchangeSourceRequests   ExchangeRequest[]               @relation("ExchangeOriginalOrder")
  exchangeOutputRequest    ExchangeRequest?                @relation("ExchangeOutputOrder")
  createdAt                DateTime                        @default(now())
  // переходы статусов — только через сервис state-machine + запись AuditEvent

  @@index([customerId])
  @@index([isDemo, createdAt])
  @@index([status])
  @@index([fulfillmentType, status])
  @@index([storePointId, status])
  @@index([posShiftId])
  @@index([pickupPoint, status])
  @@index([courierId, status])
  @@index([courierRunId])
  @@index([deliveryZoneId, status])
  @@index([deliverySlotId, status])
}

model DeliveryZone {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  fee            Int
  etaMinMinutes  Int
  etaMaxMinutes  Int
  active         Boolean        @default(true)
  createdBy      String
  idempotencyKey String         @unique
  slots          DeliverySlot[]
  orders         Order[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model DeliverySlot {
  id             String       @id @default(cuid())
  zone           DeliveryZone @relation(fields: [zoneId], references: [id])
  zoneId         String
  startsAt       DateTime
  endsAt         DateTime
  capacity       Int
  active         Boolean      @default(true)
  createdBy      String
  idempotencyKey String       @unique
  orders         Order[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([zoneId, startsAt, endsAt])
  @@index([startsAt, active])
}

model ConsignmentItem {
  id               String             @id @default(cuid())
  idempotencyKey   String             @unique
  unit             DeviceUnit         @relation(fields: [unitId], references: [id])
  unitId           String             @unique
  product          Product            @relation(fields: [productId], references: [id])
  productId        String
  ownerName        String
  ownerContact     String?
  commissionBps    Int
  status           ConsignmentStatus  @default(active)
  saleOrder        Order?             @relation("ConsignmentSaleOrder", fields: [saleOrderId], references: [id])
  saleOrderId      String?
  salePrice        Int?
  commissionAmount Int?
  ownerAmount      Int?
  soldAt           DateTime?
  payout           ConsignmentPayout? @relation(fields: [payoutId], references: [id])
  payoutId         String?
  createdBy        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([ownerName, ownerContact])
  @@index([saleOrderId])
  @@index([payoutId])
}

model ConsignmentPayout {
  id                  String                          @id @default(cuid())
  idempotencyKey      String                          @unique
  ownerName           String
  ownerContact        String?
  grossAmount         Int
  commissionAmount    Int
  ownerAmount         Int
  status              ConsignmentPayoutStatus         @default(created)
  paymentKey          String?                         @unique
  createdBy           String
  paidBy              String?
  paidAt              DateTime?
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  items               ConsignmentItem[]
  quantityAllocations QuantityConsignmentAllocation[]

  @@index([status, createdAt])
  @@index([ownerName, ownerContact])
}

model QuantityConsignmentLot {
  id             String                          @id @default(cuid())
  idempotencyKey String                          @unique
  product        Product                         @relation(fields: [productId], references: [id])
  productId      String
  balance        InventoryBalance                @relation(fields: [balanceId], references: [id])
  balanceId      String
  location       String
  ownerName      String
  ownerContact   String?
  commissionBps  Int
  receivedQty    Int
  availableQty   Int
  reservedQty    Int                             @default(0)
  createdBy      String
  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt
  allocations    QuantityConsignmentAllocation[]

  @@index([productId, location, createdAt])
  @@index([balanceId, availableQty])
  @@index([ownerName, ownerContact])
}

model QuantityConsignmentAllocation {
  id                        String                  @id @default(cuid())
  lot                       QuantityConsignmentLot  @relation(fields: [lotId], references: [id])
  lotId                     String
  orderQuantityAllocation   OrderQuantityAllocation @relation(fields: [orderQuantityAllocationId], references: [id])
  orderQuantityAllocationId String
  saleOrder                 Order?                  @relation("QuantityConsignmentSaleOrder", fields: [saleOrderId], references: [id])
  saleOrderId               String?
  qty                       Int
  returnedQty               Int                     @default(0)
  status                    ConsignmentStatus       @default(active)
  salePrice                 Int?
  commissionAmount          Int?
  ownerAmount               Int?
  returnedSaleAmount        Int                     @default(0)
  returnedCommissionAmount  Int                     @default(0)
  returnedOwnerAmount       Int                     @default(0)
  soldAt                    DateTime?
  returnedAt                DateTime?
  payout                    ConsignmentPayout?      @relation(fields: [payoutId], references: [id])
  payoutId                  String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  @@unique([orderQuantityAllocationId, lotId])
  @@index([saleOrderId, status])
  @@index([payoutId])
  @@index([lotId, status])
}

model QuantityConsignmentAdjustment {
  id           String                      @id @default(cuid())
  returnId     String
  allocationId String
  payoutId     String
  ownerName    String
  ownerContact String?
  amount       Int
  reason       String
  status       ConsignmentAdjustmentStatus @default(open)
  createdBy    String
  settledBy    String?
  settledAt    DateTime?
  createdAt    DateTime                    @default(now())

  @@unique([returnId, allocationId])
  @@index([status, createdAt])
  @@index([payoutId])
  @@index([ownerName, ownerContact])
}

model ConsignmentAdjustment {
  id           String                      @id @default(cuid())
  returnId     String
  itemId       String
  payoutId     String
  ownerName    String
  ownerContact String?
  amount       Int
  reason       String
  status       ConsignmentAdjustmentStatus @default(open)
  createdBy    String
  settledBy    String?
  settledAt    DateTime?
  createdAt    DateTime                    @default(now())

  @@unique([returnId, itemId])
  @@index([status, createdAt])
  @@index([payoutId])
  @@index([ownerName, ownerContact])
}

model OrderQuantityAllocation {
  id                     String                          @id @default(cuid())
  order                  Order                           @relation(fields: [orderId], references: [id])
  orderId                String
  orderItemId            String
  product                Product                         @relation(fields: [productId], references: [id])
  productId              String
  balance                InventoryBalance                @relation(fields: [balanceId], references: [id])
  balanceId              String
  sku                    String
  location               String
  qty                    Int
  active                 Boolean                         @default(true)
  consumedAt             DateTime?
  returnedQty            Int                             @default(0)
  createdAt              DateTime                        @default(now())
  reservation            Reservation?
  consignmentAllocations QuantityConsignmentAllocation[]

  @@index([orderId, active])
  @@index([productId])
  @@index([balanceId])
}

model OrderBundleAllocation {
  id                 String    @id @default(cuid())
  order              Order     @relation(fields: [orderId], references: [id])
  orderId            String
  orderItemId        String
  bundleSku          String
  componentProduct   Product   @relation(fields: [componentProductId], references: [id])
  componentProductId String
  componentSku       String
  location           String
  imei               String
  active             Boolean   @default(true)
  releasedAt         DateTime?
  consumedAt         DateTime?
  createdAt          DateTime  @default(now())

  @@index([orderId])
  @@index([orderId, active])
  @@index([orderItemId])
  @@index([componentProductId])
  @@index([imei])
}

model OrderItem {
  id                String       @id @default(cuid())
  order             Order        @relation(fields: [orderId], references: [id])
  orderId           String
  lineNumber        Int          @default(0)
  sku               String
  qty               Int
  price             Int
  unitCost          Int          @default(0)
  discountAmount    Int          @default(0)
  taxCode           String       @default("vat_standard")
  taxRateBps        Int          @default(1200)
  taxBaseAmount     Int          @default(0)
  taxAmount         Int          @default(0)
  imei              String?
  inventorySnapshot Json?
  returnItems       ReturnItem[]

  @@index([orderId])
  @@index([orderId, lineNumber])
}

model Payment {
  id                  String                  @id @default(cuid())
  order               Order?                  @relation(fields: [orderId], references: [id])
  orderId             String?
  serviceWorkOrder    ServiceWorkOrder?       @relation(fields: [serviceWorkOrderId], references: [id], onDelete: Restrict)
  serviceWorkOrderId  String?
  originalPayment     Payment?                @relation("PaymentRefunds", fields: [originalPaymentId], references: [id], onDelete: Restrict)
  originalPaymentId   String?
  refunds             Payment[]               @relation("PaymentRefunds")
  refundAllocations   RefundAllocation[]      @relation("RefundOriginalPayment")
  refundExecution     RefundAllocation?       @relation("RefundExecutionPayment")
  giftCard            GiftCard?               @relation(fields: [giftCardId], references: [id], onDelete: Restrict)
  giftCardId          String?
  giftCardTransaction GiftCardTransaction?
  amount              Int // отрицательное = возврат
  method              PaymentMethod
  status              PaymentStatus           @default(pending)
  shift               CashShift?              @relation(fields: [shiftId], references: [id])
  shiftId             String?
  account             AccountingAccount?      @relation(fields: [accountCode], references: [code], onDelete: Restrict)
  accountCode         String?
  accountingEntry     AccountingJournalEntry? @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)
  accountingEntryId   String?                 @unique
  idempotencyKey      String?                 @unique
  receivedBy          String?
  point               String?
  txnId               String?                 @unique // идемпотентность webhook (dedup)
  createdAt           DateTime                @default(now())

  @@index([orderId])
  @@index([serviceWorkOrderId])
  @@index([originalPaymentId])
  @@index([giftCardId])
  @@index([shiftId])
  @@index([accountCode, createdAt])
  @@index([point, createdAt])
  @@index([status, createdAt]) // dashboards/KPI/payroll filter by status + date window
}

model OnlinePaymentIntentCommand {
  id             String        @id @default(cuid())
  idempotencyKey String        @unique
  customerId     String
  orderId        String
  method         PaymentMethod
  amount         Int
  returnUrl      String?
  response       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([customerId, createdAt])
  @@index([orderId])
}

model GiftCard {
  id             String                @id @default(cuid())
  code           String                @unique
  initialBalance Int
  balance        Int
  currency       String                @default("KGS")
  status         GiftCardStatus        @default(active)
  customerId     String?
  issuedBy       String
  note           String?
  expiresAt      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  payments       Payment[]
  transactions   GiftCardTransaction[]

  @@index([customerId])
  @@index([status])
}

model CashShift {
  id                  String             @id @default(cuid())
  staffId             String
  point               String
  openCash            Int
  closeCash           Int?
  closeReason         String?
  openIdempotencyKey  String?            @unique
  closeIdempotencyKey String?            @unique
  diff                Int? // расхождение → approval + Risk
  openedAt            DateTime           @default(now())
  closedAt            DateTime?
  payments            Payment[]
  refundAllocations   RefundAllocation[]
  incassations        CashIncassation[]
  exchangeRequests    ExchangeRequest[]
  posOrders           Order[]

  @@index([staffId, closedAt]) // currentOpen() lookup on every POS sale
  @@index([diff, closedAt]) // Risk Center: closed shifts with a discrepancy
}

model CashIncassation {
  id                String                  @id @default(cuid())
  idempotencyKey    String                  @unique
  shift             CashShift               @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  shiftId           String
  point             String
  amount            Int
  destinationCode   String                  @default("1010")
  reference         String?
  status            CashIncassationStatus   @default(deposited)
  depositedBy       String
  depositedAt       DateTime                @default(now())
  reconciledAt      DateTime?
  accountingEntry   AccountingJournalEntry? @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)
  accountingEntryId String?                 @unique

  @@index([shiftId, depositedAt])
  @@index([point, depositedAt])
  @@index([status, depositedAt])
}

model CashShiftHandover {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  fromShiftId    String   @unique
  toShiftId      String   @unique
  fromStaffId    String
  toStaffId      String
  point          String
  expectedCash   Int
  countedCash    Int
  diff           Int
  reason         String?
  createdBy      String
  createdAt      DateTime @default(now())

  @@index([point, createdAt])
  @@index([toStaffId, createdAt])
}

model InventoryMovement {
  id             String       @id @default(cuid())
  idempotencyKey String?      @unique
  product        Product      @relation(fields: [productId], references: [id])
  productId      String
  qty            Int
  type           String // received | moved | write_off | adjust | count
  from           String?
  to             String?
  reason         String?
  unitCost       Int?
  totalValue     Int?
  valuationQty   Int?
  createdAt      DateTime     @default(now())
  servicePart    ServicePart?
  // write_off / adjust → owner approval + evidence

  @@index([productId])
  @@index([type])
}

// Immutable cost provenance. Product.cost is only the current catalog default;
// these rows are the accounting source for stock value and COGS.
model InventoryValuationLayer {
  id                String                    @id @default(cuid())
  product           Product                   @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId         String
  balance           InventoryBalance          @relation(fields: [balanceId], references: [id], onDelete: Cascade)
  balanceId         String
  location          String
  sourceType        String
  sourceRef         String
  unitCost          Int
  quantityReceived  Int
  quantityRemaining Int
  createdAt         DateTime                  @default(now())
  issues            InventoryValuationIssue[]

  @@unique([sourceType, sourceRef])
  @@index([productId, location, createdAt])
  @@index([balanceId, quantityRemaining, createdAt])
}

model InventoryValuationIssue {
  id          String                       @id @default(cuid())
  product     Product                      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String
  layer       InventoryValuationLayer?     @relation(fields: [layerId], references: [id], onDelete: Cascade)
  layerId     String?
  unit        DeviceUnit?                  @relation(fields: [imei], references: [imei], onDelete: Cascade)
  imei        String?
  orderId     String?
  sourceType  String
  sourceRef   String
  location    String?
  quantity    Int
  reversedQty Int                          @default(0)
  unitCost    Int
  totalCost   Int
  createdAt   DateTime                     @default(now())
  reversals   InventoryValuationReversal[]

  @@unique([sourceType, sourceRef])
  @@index([productId, createdAt])
  @@index([productId, location, createdAt])
  @@index([orderId])
  @@index([imei])
}

model InventoryValuationReversal {
  id         String                  @id @default(cuid())
  issue      InventoryValuationIssue @relation(fields: [issueId], references: [id], onDelete: Restrict)
  issueId    String
  product    Product                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId  String
  return     Return                  @relation(fields: [returnId], references: [id], onDelete: Restrict)
  returnId   String
  sourceType String
  sourceRef  String
  location   String
  quantity   Int
  unitCost   Int
  totalCost  Int
  createdAt  DateTime                @default(now())

  @@unique([sourceType, sourceRef])
  @@index([issueId, createdAt])
  @@index([productId, location, createdAt])
  @@index([returnId])
}

model Reservation {
  id                   String                   @id @default(cuid())
  orderId              String
  imei                 String?
  quantityAllocationId String?                  @unique
  quantityAllocation   OrderQuantityAllocation? @relation(fields: [quantityAllocationId], references: [id])
  expiresAt            DateTime // зависший резерв → Risk
  active               Boolean                  @default(true)

  @@index([orderId])
  @@index([imei])
  @@index([active])
}

model Return {
  id                 String                       @id @default(cuid())
  order              Order                        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId            String
  reason             String
  status             ReturnStatus                 @default(requested)
  refundId           String? // refund → approval, тем же способом
  refundAmount       Int                          @default(0)
  isFullOrder        Boolean                      @default(true)
  idempotencyKey     String?                      @unique
  restockLocation    String?
  restockedAt        DateTime?
  createdAt          DateTime                     @default(now())
  items              ReturnItem[]
  refund             Refund?
  quarantineCases    InventoryQuarantineCase[]
  valuationReversals InventoryValuationReversal[]
  exchangeRequest    ExchangeRequest?

  @@index([orderId])
  @@index([status])
}

model ReturnItem {
  id           String       @id @default(cuid())
  return       Return       @relation(fields: [returnId], references: [id], onDelete: Cascade)
  returnId     String
  orderItem    OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId  String
  qty          Int
  refundAmount Int
  createdAt    DateTime     @default(now())
  refundLines  RefundLine[]

  @@unique([returnId, orderItemId])
  @@index([orderItemId])
}

model Refund {
  id             String             @id @default(cuid())
  return         Return             @relation(fields: [returnId], references: [id], onDelete: Restrict)
  returnId       String             @unique
  order          Order              @relation(fields: [orderId], references: [id], onDelete: Restrict)
  orderId        String
  approval       Approval?          @relation(fields: [approvalId], references: [id], onDelete: Restrict)
  approvalId     String?            @unique
  idempotencyKey String             @unique
  requestHash    String
  amount         Int
  status         RefundStatus       @default(requested)
  reason         String
  requester      String
  approver       String?
  approvedAt     DateTime?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  allocations    RefundAllocation[]
  lines          RefundLine[]

  @@index([orderId, createdAt])
  @@index([status, updatedAt])
}

model RefundAllocation {
  id                  String                  @id @default(cuid())
  refund              Refund                  @relation(fields: [refundId], references: [id], onDelete: Restrict)
  refundId            String
  originalPayment     Payment                 @relation("RefundOriginalPayment", fields: [originalPaymentId], references: [id], onDelete: Restrict)
  originalPaymentId   String
  refundPayment       Payment?                @relation("RefundExecutionPayment", fields: [refundPaymentId], references: [id], onDelete: Restrict)
  refundPaymentId     String?                 @unique
  shift               CashShift?              @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  shiftId             String?
  accountingEntry     AccountingJournalEntry? @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)
  accountingEntryId   String?                 @unique
  amount              Int
  ordinal             Int
  methodSnapshot      PaymentMethod
  status              RefundAllocationStatus  @default(queued)
  providerRefundId    String?                 @unique
  attempts            Int                     @default(0)
  lastError           String?
  lockedAt            DateTime?
  nextAttemptAt       DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  giftCardTransaction GiftCardTransaction?

  @@unique([refundId, originalPaymentId])
  @@unique([refundId, ordinal])
  @@index([originalPaymentId])
  @@index([shiftId])
  @@index([status, nextAttemptAt])
  @@index([status, lockedAt])
}

model RefundLine {
  id            String     @id @default(cuid())
  refund        Refund     @relation(fields: [refundId], references: [id], onDelete: Restrict)
  refundId      String
  returnItem    ReturnItem @relation(fields: [returnItemId], references: [id], onDelete: Restrict)
  returnItemId  String
  qty           Int
  grossAmount   Int
  taxBaseAmount Int
  taxAmount     Int
  revenueAmount Int
  taxCode       String
  taxRateBps    Int
  createdAt     DateTime   @default(now())

  @@unique([refundId, returnItemId])
  @@index([returnItemId])
}

model GiftCardTransaction {
  id                 String                  @id @default(cuid())
  giftCard           GiftCard                @relation(fields: [giftCardId], references: [id], onDelete: Restrict)
  giftCardId         String
  payment            Payment?                @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  paymentId          String?                 @unique
  refundAllocation   RefundAllocation?       @relation(fields: [refundAllocationId], references: [id], onDelete: Restrict)
  refundAllocationId String?                 @unique
  type               GiftCardTransactionType
  amount             Int
  balanceAfter       Int
  sourceRef          String                  @unique
  actor              String
  createdAt          DateTime                @default(now())

  @@index([giftCardId, createdAt])
}

model WarrantyCase {
  id             String            @id @default(cuid())
  imei           String
  customerId     String
  problem        String
  status         WarrantyStatus    @default(created)
  serviceType    ServiceCaseType   @default(warranty)
  deviceName     String?
  sla            DateTime
  slaEscalatedAt DateTime?
  assignee       String?
  workOrder      ServiceWorkOrder?

  @@index([imei])
  @@index([status])
  @@index([status, sla])
  @@index([serviceType, status])
}

model ServiceWorkOrder {
  id                  String                    @id @default(cuid())
  warrantyCase        WarrantyCase              @relation(fields: [warrantyCaseId], references: [id], onDelete: Cascade)
  warrantyCaseId      String                    @unique
  technicianId        String?
  diagnosticSummary   String?
  diagnosticFee       Int                       @default(0)
  estimateAmount      Int?
  estimatePreparedAt  DateTime?
  estimateApprovedAt  DateTime?
  estimateApprovedBy  String?
  repairStartedAt     DateTime?
  repairCompletedAt   DateTime?
  repairClosedAt      DateTime?
  repairWarrantyUntil DateTime?
  completionSummary   String?
  replacementUnit     DeviceUnit?               @relation("ServiceReplacementUnit", fields: [replacementImei], references: [imei], onDelete: Restrict)
  replacementImei     String?                   @unique
  createdBy           String
  point               String
  taxCode             String                    @default("vat_standard")
  taxRateBps          Int                       @default(1200)
  taxBaseAmount       Int                       @default(0)
  taxAmount           Int                       @default(0)
  payments            Payment[]
  parts               ServicePart[]
  commands            ServiceWorkOrderCommand[]
  loanerLoans         LoanerLoan[]
  quarantineCase      InventoryQuarantineCase?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([technicianId, createdAt])
  @@index([point, createdAt])
  @@index([estimateApprovedAt, createdAt])
}

model LoanerDevice {
  id                         String       @id @default(cuid())
  unit                       DeviceUnit   @relation(fields: [unitId], references: [id], onDelete: Restrict)
  unitId                     String       @unique
  active                     Boolean      @default(true)
  condition                  String
  registeredBy               String
  registrationIdempotencyKey String       @unique
  loans                      LoanerLoan[]
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  @@index([active, createdAt])
}

model LoanerLoan {
  id                 String           @id @default(cuid())
  device             LoanerDevice     @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  deviceId           String
  workOrder          ServiceWorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  workOrderId        String
  customerId         String
  status             LoanerLoanStatus @default(prepared)
  issueCondition     String
  returnCondition    String?
  damageNote         String?
  depositAmount      Int              @default(0)
  agreementRef       String?
  dueAt              DateTime
  preparedBy         String
  preparedAt         DateTime         @default(now())
  issuedBy           String?
  issuedAt           DateTime?
  returnedBy         String?
  returnedAt         DateTime?
  overdueEscalatedAt DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([deviceId, status])
  @@index([workOrderId, status])
  @@index([customerId, createdAt])
  @@index([status, dueAt])
}

model ServicePart {
  id          String             @id @default(cuid())
  workOrder   ServiceWorkOrder   @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  workOrderId String
  product     Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId   String
  balance     InventoryBalance   @relation(fields: [balanceId], references: [id], onDelete: Restrict)
  balanceId   String
  location    String
  qty         Int
  status      ServicePartStatus  @default(reserved)
  reservedBy  String
  reservedAt  DateTime           @default(now())
  consumedBy  String?
  consumedAt  DateTime?
  releasedBy  String?
  releasedAt  DateTime?
  movement    InventoryMovement? @relation(fields: [movementId], references: [id], onDelete: Restrict)
  movementId  String?            @unique

  @@index([workOrderId, status])
  @@index([balanceId, status])
  @@index([productId, status])
}

model ServiceWorkOrderCommand {
  id             String           @id @default(cuid())
  idempotencyKey String           @unique
  workOrder      ServiceWorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  workOrderId    String
  action         String
  request        Json
  response       Json
  createdAt      DateTime         @default(now())

  @@index([workOrderId, createdAt])
}

model WarrantyOpenCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  customerId     String
  imei           String
  problem        String
  warrantyCaseId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId, createdAt])
  @@index([imei])
}

// Поставщик техники. Scorecard считается из связанных RMA.
model Supplier {
  id             String               @id @default(cuid())
  name           String               @unique
  contact        String?
  rmas           SupplierRma[]
  purchaseOrders PurchaseOrder[]
  invoices       SupplierInvoice[]
  creditNotes    SupplierCreditNote[]
  advances       SupplierAdvance[]
  statements     SupplierStatement[]
  landedCosts    LandedCost[]
  expenses       Expense[]
  createdAt      DateTime             @default(now())
}

model Expense {
  id                 String                  @id @default(cuid())
  idempotencyKey     String                  @unique
  category           String
  description        String
  amount             Int
  documentAmount     Int
  currency           String                  @default("KGS")
  exchangeRateMicros Int                     @default(1000000)
  exchangeRate       AccountingCurrencyRate? @relation(fields: [exchangeRateId], references: [id], onDelete: Restrict)
  exchangeRateId     String?
  taxMode            ExpenseTaxMode          @default(none)
  taxCode            String                  @default("none")
  taxRateBps         Int                     @default(0)
  taxBaseAmount      Int
  taxAmount          Int                     @default(0)
  point              String?
  supplier           Supplier?               @relation(fields: [supplierId], references: [id])
  supplierId         String?
  status             ExpenseStatus           @default(submitted)
  requestedBy        String
  approvedBy         String?
  rejectedBy         String?
  rejectionNote      String?
  paidBy             String?
  paymentKey         String?                 @unique
  paymentAccountCode String?
  paymentReference   String?
  incurredAt         DateTime                @default(now())
  approvedAt         DateTime?
  rejectedAt         DateTime?
  paidAt             DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([status, createdAt])
  @@index([category, incurredAt])
  @@index([supplierId])
  @@index([currency, incurredAt])
  @@index([exchangeRateId])
}

model AccountingCurrencyRate {
  id             String    @id @default(cuid())
  idempotencyKey String    @unique
  currency       String
  baseCurrency   String    @default("KGS")
  rateMicros     Int
  effectiveAt    DateTime
  source         String
  createdBy      String
  createdAt      DateTime  @default(now())
  expenses       Expense[]

  @@unique([currency, baseCurrency, effectiveAt])
  @@index([currency, baseCurrency, effectiveAt])
}

// Balanced accounting ledger. AuditEvent explains what happened; these rows
// prove where value moved and that every posted entry balances.
model AccountingAccount {
  code           String                  @id
  name           String
  type           AccountingAccountType
  system         Boolean                 @default(true)
  active         Boolean                 @default(true)
  lines          AccountingJournalLine[]
  openingBalanceLines AccountingOpeningBalanceLine[]
  bankStatements BankStatement[]
  payments       Payment[]
  createdAt      DateTime                @default(now())

  @@index([type, active])
}

model AccountingJournalEntry {
  id                 String                   @id @default(cuid())
  idempotencyKey     String                   @unique
  sourceType         String
  sourceRef          String
  description        String
  point              String?
  currency           String                   @default("KGS")
  documentAmount     Int?
  exchangeRateMicros Int                      @default(1000000)
  baseAmount         Int?
  taxCode            String                   @default("none")
  taxRateBps         Int                      @default(0)
  taxAmount          Int                      @default(0)
  occurredAt         DateTime
  postedAt           DateTime                 @default(now())
  createdBy          String
  lines              AccountingJournalLine[]
  payment            Payment?
  refundAllocation   RefundAllocation?
  purchaseReceipt    PurchaseReceipt?
  supplierInvoice    SupplierInvoice?
  supplierCreditNote SupplierCreditNote?
  supplierInvoicePayment SupplierInvoicePayment?
  supplierAdvance          SupplierAdvance?
  supplierAdvanceAllocation SupplierInvoiceAdvanceAllocation?
  supplierStatementLine    SupplierStatementLine?
  landedCost               LandedCost?
  openingBalance        AccountingOpeningBalance?
  bankStatementLine  BankStatementLine?
  cashIncassation    CashIncassation?
  taxSettlement      AccountingTaxSettlement?
  debtPlan           DebtPlan?
  reversalOfId       String?                  @unique
  reversalOf         AccountingJournalEntry?  @relation("AccountingReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversal           AccountingJournalEntry?  @relation("AccountingReversal")

  @@unique([sourceType, sourceRef])
  @@index([occurredAt, point])
  @@index([sourceType, occurredAt])
}

model AccountingOpeningBalance {
  id                String                   @id @default(cuid())
  period            String                   @unique
  documentNumber    String                   @unique
  idempotencyKey    String                   @unique
  description       String
  createdBy         String
  accountingEntryId String                   @unique
