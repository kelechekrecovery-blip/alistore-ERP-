  @@index([period, point])
}

model FinanceBudgetCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  period         String
  category       String
  point          String
  amount         Int
  budgetId       String
  response       Json
  createdAt      DateTime @default(now())

  @@index([period, point, createdAt])
  @@index([budgetId])
}

model FinanceSettlementRun {
  id              String                  @id @default(cuid())
  periodStart     DateTime
  periodEnd       DateTime
  point           String                  @default("")
  status          FinanceSettlementStatus @default(balanced)
