model CampaignRecipient {
  id            String   @id @default(cuid())
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId    String
  consentAtSend Boolean
  createdAt     DateTime @default(now())

  @@unique([campaignId, customerId])
  @@index([customerId, createdAt])
}

model OrderAttribution {
  id                String                     @id @default(cuid())
  order             Order                      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId           String                     @unique
  campaign          Campaign?                  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignId        String?
  journeyHash       String?
  firstSource       String
  firstMedium       String?
  firstCampaign     String?
  firstContent      String?
  firstTerm         String?
  firstLanding      String?
  lastSource        String
  lastMedium        String?
  lastCampaign      String?
  lastContent       String?
  lastTerm          String?
  lastLanding       String?
  capturedAt        DateTime
  convertedAt       DateTime?
  revenue           Int                        @default(0)
  grossProfit       Int                        @default(0)
  refundedRevenue   Int                        @default(0)
  refundedCost      Int                        @default(0)
  refundAdjustments CampaignRefundAdjustment[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([campaignId, convertedAt])
  @@index([lastSource, lastMedium])
}

model CampaignFunnelEvent {
  id          String              @id @default(cuid())
  campaign    Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId  String
  sessionHash String
  stage       CampaignFunnelStage
  orderId     String?
  createdAt   DateTime            @default(now())

  @@unique([campaignId, sessionHash, stage])
  @@index([campaignId, stage, createdAt])
  @@index([orderId])
}

model CampaignRefundAdjustment {
  id              String           @id @default(cuid())
  campaign        Campaign         @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  campaignId      String
  attribution     OrderAttribution @relation(fields: [attributionId], references: [id], onDelete: Cascade)
  attributionId   String
  refundPaymentId String           @unique
  returnId        String?
  revenue         Int
  restoredCost    Int
  createdAt       DateTime         @default(now())

  @@index([campaignId, createdAt])
  @@index([attributionId, createdAt])
}

model CampaignSpendEntry {
  id             String   @id @default(cuid())
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  campaignId     String
  idempotencyKey String   @unique
  provider       String
  externalRef    String
  amount         Int
  occurredAt     DateTime
  actor          String
  createdAt      DateTime @default(now())

  @@unique([provider, externalRef])
  @@index([campaignId, occurredAt])
}

model StorefrontContentRevision {
  id                 String    @id @default(cuid())
  version            Int       @unique
  status             String    @default("draft")
  heroEyebrow        String
  heroTitle          String
  heroBody           String
  heroCtaLabel       String
  heroCtaHref        String
  heroImageUrl       String?
  financingText      String?
  aboutTitle         String
  aboutBody          String
  deliveryTitle      String
  deliveryBody       String
  contactPhone       String?
  supportHours       String?
  benefits           Json
  featuredTitle      String    @default("Подборка AliStore")
  featuredProductIds String[]  @default([])
  createdBy          String
  publishedBy        String?
  scheduledBy        String?
  createdAt          DateTime  @default(now())
  publishedAt        DateTime?
  startsAt           DateTime?
  endsAt             DateTime?

  @@index([status, publishedAt])
  @@index([status, startsAt, endsAt])
}

model SupportTicket {
  id             String       @id @default(cuid())
  customerId     String // ссылка строкой, без @relation (см. Customer)
  channel        String // web | app | whatsapp | telegram | call | store
  subject        String
  body           String?
  priority       String // normal | high | urgent (эскалация повышает уровень)
  sla            DateTime
  status         TicketStatus @default(new)
  assignee       String?
  idempotencyKey String?      @unique
  createdAt      DateTime     @default(now())

  @@index([customerId])
  @@index([status])
}

// Business buyer profile is customer-owned but intentionally stores customerId
// without a foreign key, matching SupportTicket/WarrantyCase test isolation.
model BusinessBuyerProfile {
  id             String   @id @default(cuid())
  customerId     String   @unique
  companyName    String
  taxId          String
  contactName    String
  email          String?
  billingAddress String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyName])
}

model B2BQuote {
  id              String         @id @default(cuid())
  customerId      String
  status          B2BQuoteStatus @default(requested)
  paymentIntent   String         @default("invoice") // invoice | bank_transfer
  fulfillmentType String         @default("delivery") // delivery | pickup
  deliveryAddress String?
  pickupPoint     String?
  comment         String?
  staffNote       String?
  listTotal       Int
  quotedTotal     Int?
  validUntil      DateTime?
  items           B2BQuoteItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([customerId, createdAt])
  @@index([status, createdAt])
}

model B2BQuoteItem {
  id          String   @id @default(cuid())
  quote       B2BQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String
  sku         String
  name        String
  qty         Int
  listPrice   Int
  targetPrice Int?

  @@index([quoteId])
  @@index([sku])
}

model DeviceProtectionPolicy {
  id             String           @id @default(cuid())
  customerId     String
  orderId        String
  imei           String
  productName    String
  planType       String // accidental_damage | extended_warranty | full_protection
  status         ProtectionStatus @default(requested)
  deviceValue    Int
  premium        Int?
  coverageMonths Int
  staffNote      String?
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@index([imei])
}

// ---------- AUTH ----------
enum OtpPurpose {
  login
}

// One-time login code (phone+OTP). Code stored hashed; short-lived; attempt-capped.
model OtpChallenge {
  id         String     @id @default(cuid())
  phone      String
  codeHash   String
  purpose    OtpPurpose @default(login)
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([phone])
}

// Rotating refresh token, stored as a sha-256 hash and single-use (revoked on
// refresh). customerId is a plain indexed string to avoid coupling the Customer
// model that other modules edit concurrently.
model RefreshToken {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([customerId])
}

// ---------- OUTBOX ----------
enum OutboxStatus {
  pending
  sent
  failed
  cancelled
}

// Transactional outbox for guaranteed-delivery side-effects (notifications,
// webhook follow-ups). Producers write a message in the SAME transaction as the
// business change (invariant #10); a pg-boss relay delivers it with retries.
model OutboxMessage {
  id         String       @id @default(cuid())
  campaign   Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignId String?
  channel    String // sms | email | push | telegram | webhook
  recipient  String
  template   String
  payload    Json
  status     OutboxStatus @default(pending)
  attempts   Int          @default(0)
  lastError  String?
  createdAt  DateTime     @default(now())
  sentAt     DateTime?

  @@index([status])
  @@index([campaignId, status])
}

// Durable compensation queue for media objects that were uploaded before a
// later database validation failed. Deletion is idempotent and retried until
// the object store accepts it.
model MediaCleanupTask {
  id               String    @id @default(cuid())
  objectKey        String    @unique
  attempts         Int       @default(0)
  deletePasses     Int       @default(0)
  lastError        String?
  nextAttemptAt    DateTime  @default(now())
  uploadLeaseUntil DateTime
  claimedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([completedAt, nextAttemptAt, uploadLeaseUntil, claimedAt])
}

// ---------- STAFF AUTH ----------
// Staff login carries a role in the JWT so dangerous actions are authorized on
// the server (Role Permission Matrix), not trusted from the request body.
model StaffUser {
  id             String          @id @default(cuid())
  username       String          @unique
  passwordHash   String
  role           Role
  point          String          @default("BISHKEK-1")
  active         Boolean         @default(true)
  totpSecret     String?
  totpEnabled    Boolean         @default(false)
  totpLastToken  String? // last used TOTP code — single-use guard (anti-replay)
  pushTokens     PushToken[]
  assignedTasks  StaffTask[]     @relation("StaffTaskAssignee")
  createdTasks   StaffTask[]     @relation("StaffTaskCreator")
  courierOrders  Order[]         @relation("OrderCourier")
  hrSchedules    HrSchedule[]
  hrAttendances  HrAttendance[]
  hrAbsences     HrAbsence[]
  hrPayrollLines HrPayrollLine[]
  createdAt      DateTime        @default(now())

  @@index([role])
}

model HrSchedule {
  id             String        @id @default(cuid())
  staff          StaffUser     @relation(fields: [staffId], references: [id])
  staffId        String
  point          String
  shiftDate      DateTime      @db.Date
  startsAt       DateTime
  endsAt         DateTime
  createdBy      String
  idempotencyKey String        @unique
  attendance     HrAttendance?
  cancelledAt    DateTime?
  cancelledBy    String?
  cancelReason   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([staffId, shiftDate])
  @@index([point, shiftDate])
}

model HrScheduleCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  scheduleId     String
  action         String
  request        Json
  response       Json
  createdAt      DateTime @default(now())

  @@index([scheduleId, createdAt])
}

model HrAttendance {
  id           String     @id @default(cuid())
  schedule     HrSchedule @relation(fields: [scheduleId], references: [id])
  scheduleId   String     @unique
  staff        StaffUser  @relation(fields: [staffId], references: [id])
  staffId      String
  point        String
  checkedInAt  DateTime
  checkedOutAt DateTime?
  checkInKey   String     @unique
  checkOutKey  String?    @unique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([staffId, checkedInAt])
  @@index([point, checkedInAt])
}

model HrAbsence {
  id             String          @id @default(cuid())
  staff          StaffUser       @relation(fields: [staffId], references: [id])
  staffId        String
  type           HrAbsenceType
  startsOn       DateTime        @db.Date
  endsOn         DateTime        @db.Date
  reason         String?
  status         HrAbsenceStatus @default(requested)
  createdBy      String
  decidedBy      String?
  decidedAt      DateTime?
  decisionNote   String?
  idempotencyKey String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([staffId, startsOn, endsOn])
  @@index([status, startsOn])
}

model HrPayrollRun {
  id                   String          @id @default(cuid())
  period               String
  point                String
  status               HrPayrollStatus @default(posted)
  baseAmount           Int
  commissionBps        Int
  latePenaltyPerMinute Int
  overtimePayPerMinute Int
  totalBase            Int
  totalCommission      Int
  totalAdjustments     Int
  totalPayout          Int
  createdBy            String
  paidBy               String?
  paidAt               DateTime?
  externalRef          String?
  lines                HrPayrollLine[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([period, point])
  @@index([status, createdAt])
}

model HrPayrollLine {
  id                String       @id @default(cuid())
  run               HrPayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId             String
  staff             StaffUser    @relation(fields: [staffId], references: [id])
  staffId           String
  username          String
  plannedShifts     Int
  completedShifts   Int
  paidAbsenceShifts Int
  workedMinutes     Int
  lateMinutes       Int
  overtimeMinutes   Int
  revenue           Int
  sales             Int
  baseEarned        Int
  commission        Int
  lateDeduction     Int
  overtimePay       Int
  total             Int
  createdAt         DateTime     @default(now())

  @@unique([runId, staffId])
  @@index([staffId, createdAt])
}

model HrPayrollCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  action         String
  runId          String?
  request        Json
  response       Json
  createdAt      DateTime @default(now())

  @@index([runId, createdAt])
}

enum StaffTaskStatus {
  open
  in_progress
  completed
  cancelled
}

enum StaffTaskPriority {
  low
  normal
  high
  urgent
}

model StaffTask {
  id          String            @id @default(cuid())
  title       String
  description String?
  status      StaffTaskStatus   @default(open)
  priority    StaffTaskPriority @default(normal)
  assigneeId  String
  assignee    StaffUser         @relation("StaffTaskAssignee", fields: [assigneeId], references: [id])
  createdById String
  createdBy   StaffUser         @relation("StaffTaskCreator", fields: [createdById], references: [id])
  dueAt       DateTime?
  relatedType String?
  relatedId   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  completedAt DateTime?

  @@index([assigneeId, status])
  @@index([dueAt])
}
