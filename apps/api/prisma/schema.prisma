  @@index([runId, status])
}

model FinanceSettlementCommand {
  idempotencyKey String   @id
  action         String
  runId          String?
  input          Json
  response       Json
  createdBy      String
  createdAt      DateTime @default(now())

  @@index([runId, createdAt])
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  number         String              @unique
  idempotencyKey String?             @unique
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  supplierId     String
  status         PurchaseOrderStatus @default(draft)
  location       String
  note           String?
  createdBy      String
  sentAt         DateTime?
  receivedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  items          PurchaseOrderItem[]
  receipts       PurchaseReceipt[]
  invoices       SupplierInvoice[]
  landedCosts    LandedCost[]

  @@index([supplierId, createdAt])
  @@index([status, createdAt])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  product         Product       @relation(fields: [productId], references: [id])
  productId       String
  orderedQty      Int
  receivedQty     Int           @default(0)
  unitCost        Int

  @@unique([purchaseOrderId, productId])
  @@index([productId])
}

model PurchaseReceipt {
  id                String                  @id @default(cuid())
  purchaseOrder     PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId   String
  idempotencyKey    String
  actor             String
  payload           Json
  accountingEntryId String?                 @unique
  accountingEntry   AccountingJournalEntry? @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)
  createdAt         DateTime                @default(now())

  @@unique([purchaseOrderId, idempotencyKey])
  @@index([purchaseOrderId, createdAt])
}

model SupplierInvoice {
  id                  String                  @id @default(cuid())
  supplier            Supplier                @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierId          String
  purchaseOrder       PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  purchaseOrderId     String
  invoiceNumber       String
  idempotencyKey      String                  @unique
  amount              Int
  matchedReceiptValue Int
  dueDate             DateTime?
  status              SupplierInvoiceStatus   @default(draft)
  approvedBy          String?
  approvedAt          DateTime?
  paymentKey          String?                 @unique
  paymentAccountCode  String?
  paymentReference    String?
  paidBy              String?
  paidAt              DateTime?
  accountingEntryId   String?                 @unique
  accountingEntry     AccountingJournalEntry? @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)
  payments            SupplierInvoicePayment[]
  advanceAllocations  SupplierInvoiceAdvanceAllocation[]
  creditNotes         SupplierCreditNote[]
  createdBy           String
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@unique([supplierId, invoiceNumber])
  @@index([status, dueDate])
  @@index([supplierId, createdAt])
  @@index([purchaseOrderId])
}

model SupplierInvoicePayment {
  id                 String                  @id @default(cuid())
  invoice            SupplierInvoice         @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  invoiceId          String
  idempotencyKey     String                  @unique
  paymentKey         String                  @unique
  amount             Int
  paymentAccountCode String
  paymentReference   String
  paidBy             String
  paidAt             DateTime                @default(now())
  accountingEntryId  String                  @unique
  accountingEntry    AccountingJournalEntry @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)
  createdAt          DateTime                @default(now())

  @@index([invoiceId, paidAt])
  @@index([paymentAccountCode, paidAt])
}

model SupplierAdvance {
  id                 String               @id @default(cuid())
  supplier           Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierId         String
  idempotencyKey     String               @unique
  paymentKey         String               @unique
  amount             Int
  appliedAmount      Int                  @default(0)
  status             SupplierAdvanceStatus @default(open)
  paymentAccountCode String
  paymentReference   String
  paidBy             String
  paidAt             DateTime             @default(now())
  accountingEntryId  String               @unique
  accountingEntry    AccountingJournalEntry @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)
  allocations        SupplierInvoiceAdvanceAllocation[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([supplierId, status, createdAt])
  @@index([status, paidAt])
}

model SupplierInvoiceAdvanceAllocation {
  id                 String          @id @default(cuid())
  advance            SupplierAdvance @relation(fields: [advanceId], references: [id], onDelete: Restrict)
  advanceId          String
  invoice            SupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  invoiceId          String
  idempotencyKey     String          @unique
  amount             Int
  accountingEntryId  String          @unique
  accountingEntry    AccountingJournalEntry @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)
  appliedBy          String
  appliedAt          DateTime        @default(now())

  @@index([advanceId, appliedAt])
  @@index([invoiceId, appliedAt])
}

model SupplierStatement {
  id              String                  @id @default(cuid())
  supplier        Supplier                @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierId      String
  statementNumber String                  @unique
  idempotencyKey  String                  @unique
  periodStart     DateTime
  periodEnd       DateTime
  openingBalance  Int
  closingBalance  Int
  status          SupplierStatementStatus @default(imported)
  createdBy       String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  lines           SupplierStatementLine[]

  @@index([supplierId, periodStart, periodEnd])
  @@index([status, createdAt])
}

model SupplierStatementLine {
  id                String                       @id @default(cuid())
  statement         SupplierStatement            @relation(fields: [statementId], references: [id], onDelete: Cascade)
  statementId       String
  externalId        String
  occurredAt        DateTime
  amount            Int
  reference         String?
  status            SupplierStatementLineStatus  @default(unmatched)
  reconciliationKey String?                      @unique
  matchedEntryId    String?                      @unique
  matchedEntry      AccountingJournalEntry?      @relation(fields: [matchedEntryId], references: [id], onDelete: Restrict)
  matchedBy         String?
  matchedAt         DateTime?
  createdAt         DateTime                     @default(now())

  @@unique([statementId, externalId])
  @@index([statementId, status])
  @@index([occurredAt, amount])
}

// Additional acquisition costs are capitalized into the received serialized
// units and the inventory asset account in one immutable document.
model LandedCost {
  id                 String                  @id @default(cuid())
  purchaseOrder      PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  purchaseOrderId    String
  supplier           Supplier                @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierId         String
  idempotencyKey     String                  @unique
  documentNumber     String                  @unique
  amount             Int
  creditAccountCode  String
  description        String
  appliedBy          String
  appliedAt          DateTime                @default(now())
  accountingEntryId  String                  @unique
  accountingEntry    AccountingJournalEntry @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)
  allocations        LandedCostAllocation[]
  createdAt          DateTime                @default(now())

  @@index([purchaseOrderId, createdAt])
  @@index([supplierId, createdAt])
}

model LandedCostAllocation {
  id              String     @id @default(cuid())
  landedCost      LandedCost @relation(fields: [landedCostId], references: [id], onDelete: Restrict)
  landedCostId    String
  unit            DeviceUnit @relation(fields: [unitId], references: [id], onDelete: Restrict)
  unitId          String
  imei            String
  product         Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId       String
  baseCost        Int
  allocatedAmount Int
  resultingCost   Int
  createdAt       DateTime   @default(now())

  @@unique([landedCostId, unitId])
  @@index([unitId, createdAt])
  @@index([productId, createdAt])
}

model SupplierCreditNote {
  id                String                   @id @default(cuid())
  supplier          Supplier                 @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierId        String
  invoice           SupplierInvoice          @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  invoiceId         String
  noteNumber        String
  idempotencyKey    String                   @unique
  amount            Int
  reason            String
  status            SupplierCreditNoteStatus @default(draft)
  approvedBy        String?
  approvedAt        DateTime?
  appliedBy         String?
  appliedAt         DateTime?
  accountingEntryId String?                  @unique
  accountingEntry   AccountingJournalEntry?  @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)
  createdBy         String
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([supplierId, noteNumber])
  @@index([invoiceId, status])
  @@index([supplierId, createdAt])
}

model BankStatement {
  id              String              @id @default(cuid())
  account         AccountingAccount   @relation(fields: [accountCode], references: [code], onDelete: Restrict)
  accountCode     String
  statementNumber String              @unique
  idempotencyKey  String              @unique
  periodStart     DateTime
  periodEnd       DateTime
  openingBalance  Int
  closingBalance  Int
  status          BankStatementStatus @default(imported)
  createdBy       String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  lines           BankStatementLine[]

  @@index([accountCode, periodStart, periodEnd])
  @@index([status, createdAt])
}

model BankStatementLine {
  id                String                  @id @default(cuid())
  statement         BankStatement           @relation(fields: [statementId], references: [id], onDelete: Cascade)
  statementId       String
  externalId        String
  occurredAt        DateTime
  amount            Int
  reference         String?
  status            BankStatementLineStatus @default(unmatched)
  reconciliationKey String?                 @unique
  matchedEntryId    String?                 @unique
  matchedEntry      AccountingJournalEntry? @relation(fields: [matchedEntryId], references: [id], onDelete: Restrict)
  matchedBy         String?
  matchedAt         DateTime?
  createdAt         DateTime                @default(now())

  @@unique([statementId, externalId])
  @@index([statementId, status])
  @@index([occurredAt, amount])
}

// Возврат брака поставщику (RMA). Машина статусов + SLA; просрочка → Risk Center.
model SupplierRma {
  id         String    @id @default(cuid())
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  supplierId String
  imei       String
  defect     String
  status     RmaStatus @default(created)
  sla        DateTime
  resolution String? // repaired | replaced | refunded | rejected — итог для scorecard
  createdAt  DateTime  @default(now())

  @@index([supplierId])
  @@index([imei])
  @@index([status])
}

// Продажа в долг / рассрочка. Долг сверх лимита — через approval (action=debt).
// balance гасится платежами; просрочка (open + dueDate<now) → Risk Center.
model DebtPlan {
  id                String                  @id @default(cuid())
  orderId           String                  @unique
  customerId        String
  principal         Int // исходная сумма долга
  balance           Int // остаток к погашению
  installments      Int                     @default(1) // число платежей (рассрочка)
  dueDate           DateTime
  status            DebtStatus              @default(open)
  idempotencyKey    String?                 @unique
  accountingEntry   AccountingJournalEntry? @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)
  accountingEntryId String?                 @unique
  createdAt         DateTime                @default(now())

  @@index([customerId])
  @@index([status])
}

model TradeInDevice {
  id             String   @id @default(cuid())
  customer       Customer @relation(fields: [customerId], references: [id])
  customerId     String // PII: паспорт продавца
  model          String
  grade          Grade
  price          Int
  contractId     String?
  sellerPassport String // защищённое поле + anti-fraud
  imei           String? // anti-fraud: тот же IMEI в скупке И в продаже → risk-флаг
  idempotencyKey String?  @unique

  @@index([customerId])
  @@index([imei])
}

model CourierRun {
  id                       String    @id @default(cuid())
  courierId                String
  codTotal                 Int // COD не сдан >24ч → Risk
  handedOver               Boolean   @default(false)
  collectedTotal           Int       @default(0)
  assignmentIdempotencyKey String?   @unique
  handoverIdempotencyKey   String?   @unique
  handoverAmount           Int?
  handoverReason           String?
  handedOverAt             DateTime?
  orders                   Order[]
  createdAt                DateTime  @default(now())

  @@index([courierId])
  @@index([handedOver])
}

model CourierCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  courierId      String
  orderId        String
  action         String
  payload        Json
  response       Json?
  createdAt      DateTime @default(now())

  @@index([courierId, createdAt])
  @@index([orderId, createdAt])
}

model Approval {
  id                    String                   @id @default(cuid())
  action                String // discount | refund | write_off | quarantine_write_off | price | debt | delete | stock_adjust | pii
  requester             String
  approver              String?
  status                ApprovalStatus           @default(requested)
  reason                String
  evidence              Json? // обязательно для high-risk
  createdAt             DateTime                 @default(now())
  refund                Refund?
  quarantineDisposition InventoryQuarantineCase?
  exchangeRequest       ExchangeRequest?

  @@index([status])
  @@index([action])
}

model ExchangeRequest {
  id                String        @id @default(cuid())
  idempotencyKey    String        @unique
  approvalId        String        @unique
  approval          Approval      @relation(fields: [approvalId], references: [id], onDelete: Restrict)
  status            String        @default("requested")
  requester         String
  originalOrder     Order         @relation("ExchangeOriginalOrder", fields: [originalOrderId], references: [id], onDelete: Restrict)
  originalOrderId   String
  oldUnit           DeviceUnit    @relation("ExchangeReturnedUnit", fields: [oldImei], references: [imei], onDelete: Restrict)
  oldImei           String
  newProduct        Product       @relation("ExchangeReplacementProduct", fields: [newProductId], references: [id], onDelete: Restrict)
  newProductId      String
  newUnit           DeviceUnit    @relation("ExchangeReplacementUnit", fields: [newUnitId], references: [id], onDelete: Restrict)
  newUnitId         String
  newImei           String
  creditAmount      Int
  surchargeAmount   Int
  method            PaymentMethod
  shift             CashShift?    @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  shiftId           String?
  externalReference String?
  exchangeOrder     Order?        @relation("ExchangeOutputOrder", fields: [exchangeOrderId], references: [id], onDelete: Restrict)
  exchangeOrderId   String?       @unique
  return            Return?       @relation(fields: [returnId], references: [id], onDelete: Restrict)
  returnId          String?       @unique
  expiresAt         DateTime
  executedAt        DateTime?
  rejectedAt        DateTime?
  expiredAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([originalOrderId])
  @@index([oldImei])
  @@index([newImei])
  @@index([newUnitId])
}

// Неизменяемо. Только append. Никаких update/delete. Источник правды.
model AuditEvent {
  id      String   @id @default(cuid())
  type    String // order.* payment.* stock.* approval.* и т.д.
  actor   String
  ts      DateTime @default(now())
  payload Json
  refs    String[] // связанные id (orderId, imei, shiftId…)

  @@index([type])
  @@index([actor])
  @@index([refs], type: Gin) // array-containment (has/hasEvery) needs GIN, not B-tree
}

// A successful multipart upload is replayable by its caller's idempotency key.
// The stored asset is returned on retry and the EvidenceAttached ledger event
// is emitted exactly once.
model EvidenceUpload {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  actor          String
  entityType     String
  entityId       String
  label          String?
  fingerprint    String
  asset          Json
  createdAt      DateTime @default(now())

  @@index([entityType, entityId])
}

model Campaign {
  id                String                     @id @default(cuid())
  name              String                     @default("Campaign")
  trackingCode      String                     @unique
  status            CampaignLifecycleStatus    @default(draft)
  source            String                     @default("alistore")
  medium            String
  promotionCode     String?
  segment           String
  channel           String
  budget            Int
  creativeType      CampaignCreativeType       @default(text)
  creativeHeadline  String
  creativeBody      String?
  creativeAssetUrl  String?
  creativeCtaLabel  String?
  destinationUrl    String                     @default("/")
  template          String                     @default("campaign_offer")
  approvalId        String?                    @unique
  rejectionReason   String?
  createdBy         String
  updatedBy         String
  approvedBy        String?
  reviewedAt        DateTime?
  approvedAt        DateTime?
  activatedAt       DateTime?
  pausedAt          DateTime?
  completedAt       DateTime?
  orders            Int                        @default(0)
  revenue           Int                        @default(0)
  grossProfit       Int                        @default(0)
