// AliStore — Prisma schema (PostgreSQL)
// Origin: design_handoff_alistore/reference/schema.prisma («API Data Contracts»).
// Faithful to the reference. Two kinds of adaptation applied, both non-behavioral:
//   1. Payment<->CashShift made into a real Prisma relation (reference declared only
//      one side, which fails `prisma validate`).
//   2. @@index added on hot query paths. No field semantics changed.
// Business invariants (see docs/AliStore Business Invariants.md) are enforced in the
// service layer inside transactions, not by the schema alone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS ----------
enum Role {
  seller
  senior_seller
  cashier
  warehouse
  courier
  marketer
  admin
  owner
  franchise
}

enum OrderStatus {
  draft
  created
  awaiting_confirmation
  confirmed
  reserved
  awaiting_payment
  paid
  picking
  packed
  ready_for_pickup
  courier_assigned
  out_for_delivery
  delivered
  completed
  cancelled
  return_requested
  returned
  exchanged
  refunded
}

enum PaymentMethod {
  cash
  card
  qr_mbank
  qr_odengi
  bakai_pos
  obank
  installment
  gift_card
}

enum PaymentStatus {
  pending
  received
  reconciled
  disputed
  refunded
}

enum UnitStatus {
  in_stock
  reserved
  sold
  returned
  in_repair
  written_off
}

enum Grade {
  A
  B
  C
}

enum ApprovalStatus {
  requested
  approved
  rejected
}

enum ReturnStatus {
  requested
  under_review
  approved
  rejected
  processing
  paid
  reconciled
}

enum WarrantyStatus {
  created
  received
  diagnostics
  waiting_supplier
  approved
  rejected
  repaired
  replaced
  closed
}

enum TicketStatus {
  new
  in_progress
  waiting
  resolved
  closed
}

enum RmaStatus {
  created
  shipped
  accepted
  repaired
  replaced
  refunded
  rejected
  closed
}

enum DebtStatus {
  open
  settled
  written_off
}

enum GiftCardStatus {
  active
  redeemed
  cancelled
  expired
}

enum B2BQuoteStatus {
  requested
  reviewing
  quoted
  accepted
  rejected
}

enum ProtectionStatus {
  requested
  reviewing
  offered
  active
  rejected
  cancelled
}

enum PurchaseOrderStatus {
  draft
  sent
  receiving
  received
  cancelled
}

enum ExpenseStatus {
  submitted
  approved
  rejected
  paid
}

// ---------- CORE ----------
model Customer {
  id             String               @id @default(cuid())
  phone          String               @unique // PII — маскировать младшим ролям
  name           String
  consent        Boolean              @default(false) // маркетинг только при true
  segments       String[]
  ltv            Int                  @default(0)
  identities     CustomerIdentity[]
  pushTokens     PushToken[]
  addresses      CustomerAddress[]
  preferences    CustomerPreferences?
  loyaltyEntries LoyaltyEntry[]
  coupons        CustomerCoupon[]
  orders         Order[]
  tradeIns       TradeInDevice[]
  createdAt      DateTime             @default(now())
  // SupportTicket ссылается на customerId строкой (как WarrantyCase/DebtPlan) —
  // без @relation, чтобы очистка в тестах не каскадила через FK.
}

model CustomerAddress {
  id             String   @id @default(cuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title          String
  text           String
  comment        String?
  isPrimary      Boolean  @default(false)
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId, isPrimary])
}

model CustomerPreferences {
  customerId String   @id
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  push       Boolean  @default(true)
  whatsapp   Boolean  @default(true)
  service    Boolean  @default(true)
  promos     Boolean  @default(false)
  updatedAt  DateTime @updatedAt
}

model LoyaltyEntry {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  kind       String    @default("adjustment") // earn | redeem | refund_restore | refund_clawback | adjustment
  label      String
  amount     Int
  sourceRef  String?   @unique
  orderId    String?
  paymentId  String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([customerId, createdAt])
  @@index([orderId])
  @@index([paymentId])
}

model CustomerCoupon {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title      String
  code       String
  valueLabel String
  expiresAt  DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@unique([customerId, code])
  @@index([customerId, active])
}

model CustomerIdentity {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider    String
  subject     String
  email       String?
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, subject])
  @@index([customerId])
}

model PushToken {
  id         String     @id @default(cuid())
  token      String     @unique
  platform   String
  deviceId   String
  appScope   String     @default("anonymous") // anonymous | customer | staff
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staffId    String?
  staff      StaffUser? @relation(fields: [staffId], references: [id], onDelete: Cascade)
  enabled    Boolean    @default(true)
  lastSeenAt DateTime   @default(now())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([customerId, enabled])
  @@index([staffId, enabled])
  @@index([platform])
}

model Product {
  id                 String              @id @default(cuid())
  sku                String              @unique
  name               String
  price              Int
  cost               Int
  category           String
  attrs              Json
  archived           Boolean             @default(false) // soft-delete: НЕ удалять физически
  updatedAt          DateTime            @default(now()) @updatedAt
  units              DeviceUnit[]
  movements          InventoryMovement[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([category])
  @@index([archived])
  @@index([updatedAt])
}

model ProductReview {
  id           String   @id @default(cuid())
  productId    String
  sku          String
  customerId   String
  customerName String
  orderId      String
  rating       Int
  text         String?
  createdAt    DateTime @default(now())

  @@unique([productId, customerId, orderId])
  @@index([productId])
  @@index([customerId])
  @@index([orderId])
}

model DeviceUnit {
  id        String     @id @default(cuid())
  imei      String     @unique // один IMEI нельзя продать дважды
  product   Product    @relation(fields: [productId], references: [id])
  productId String
  status    UnitStatus @default(in_stock)
  grade     Grade?
  location  String
  orderId   String?
  updatedAt DateTime   @default(now()) @updatedAt
  // повтор IMEI в trade-in + продаже → risk-флаг (проверка на сервере)

  @@index([productId])
  @@index([status])
  @@index([orderId])
  @@index([updatedAt])
}

model Order {
  id              String      @id @default(cuid())
  idempotencyKey  String?     @unique
  isDemo          Boolean     @default(false)
  customer        Customer    @relation(fields: [customerId], references: [id])
  customerId      String
  status          OrderStatus @default(draft)
  channel         String // web | app | mobile | pos | telegram
  fulfillmentType String      @default("pickup") // pickup | courier | express | store
  pickupPoint     String?
  deliveryAddress String?
  deliverySlot    String?
  courierId       String?
  courier         StaffUser?  @relation("OrderCourier", fields: [courierId], references: [id])
  courierRunId    String?
  courierRun      CourierRun? @relation(fields: [courierRunId], references: [id])
  pickupCode      String?
  subtotal        Int         @default(0)
  deliveryFee     Int         @default(0)
  promoCode       String?
  promoDiscount   Int         @default(0)
  loyaltyRedeemed Int         @default(0)
  loyaltyEarned   Int         @default(0)
  total           Int
  items           OrderItem[]
  payments        Payment[]
  createdAt       DateTime    @default(now())
  // переходы статусов — только через сервис state-machine + запись AuditEvent

  @@index([customerId])
  @@index([isDemo, createdAt])
  @@index([status])
  @@index([fulfillmentType, status])
  @@index([pickupPoint, status])
  @@index([courierId, status])
  @@index([courierRunId])
}

model OrderItem {
  id      String  @id @default(cuid())
  order   Order   @relation(fields: [orderId], references: [id])
  orderId String
  sku     String
  qty     Int
  price   Int
  imei    String?

  @@index([orderId])
}

model Payment {
  id        String        @id @default(cuid())
  order     Order?        @relation(fields: [orderId], references: [id])
  orderId   String?
  amount    Int // отрицательное = возврат
  method    PaymentMethod
  status    PaymentStatus @default(pending)
  shift     CashShift?    @relation(fields: [shiftId], references: [id])
  shiftId   String?
  txnId     String?       @unique // идемпотентность webhook (dedup)
  createdAt DateTime      @default(now())

  @@index([orderId])
  @@index([shiftId])
  @@index([status, createdAt]) // dashboards/KPI/payroll filter by status + date window
}

model OnlinePaymentIntentCommand {
  id             String        @id @default(cuid())
  idempotencyKey String        @unique
  customerId     String
  orderId        String
  method         PaymentMethod
  amount         Int
  returnUrl      String?
  response       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([customerId, createdAt])
  @@index([orderId])
}

model GiftCard {
  id             String         @id @default(cuid())
  code           String         @unique
  initialBalance Int
  balance        Int
  currency       String         @default("KGS")
  status         GiftCardStatus @default(active)
  customerId     String?
  issuedBy       String
  note           String?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([customerId])
  @@index([status])
}

model CashShift {
  id                  String    @id @default(cuid())
  staffId             String
  point               String
  openCash            Int
  closeCash           Int?
  closeReason         String?
  openIdempotencyKey  String?   @unique
  closeIdempotencyKey String?   @unique
  diff                Int? // расхождение → approval + Risk
  openedAt            DateTime  @default(now())
  closedAt            DateTime?
  payments            Payment[]

  @@index([staffId, closedAt]) // currentOpen() lookup on every POS sale
  @@index([diff, closedAt]) // Risk Center: closed shifts with a discrepancy
}

model InventoryMovement {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  qty       Int
  type      String // received | moved | write_off | adjust | count
  from      String?
  to        String?
  reason    String?
  createdAt DateTime @default(now())
  // write_off / adjust → owner approval + evidence

  @@index([productId])
  @@index([type])
}

model Reservation {
  id        String   @id @default(cuid())
  orderId   String
  imei      String?
  expiresAt DateTime // зависший резерв → Risk
  active    Boolean  @default(true)

  @@index([orderId])
  @@index([imei])
  @@index([active])
}

model Return {
  id             String       @id @default(cuid())
  orderId        String
  reason         String
  status         ReturnStatus @default(requested)
  refundId       String? // refund → approval, тем же способом
  idempotencyKey String?      @unique
  createdAt      DateTime     @default(now())

  @@index([orderId])
  @@index([status])
}

model WarrantyCase {
  id         String         @id @default(cuid())
  imei       String
  customerId String
  problem    String
  status     WarrantyStatus @default(created)
  sla        DateTime
  assignee   String?

  @@index([imei])
  @@index([status])
}

model WarrantyOpenCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  customerId     String
  imei           String
  problem        String
  warrantyCaseId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId, createdAt])
  @@index([imei])
}

// Поставщик техники. Scorecard считается из связанных RMA.
model Supplier {
  id             String          @id @default(cuid())
  name           String          @unique
  contact        String?
  rmas           SupplierRma[]
  purchaseOrders PurchaseOrder[]
  expenses       Expense[]
  createdAt      DateTime        @default(now())
}

model Expense {
  id             String        @id @default(cuid())
  idempotencyKey String        @unique
  category       String
  description    String
  amount         Int
  point          String?
  supplier       Supplier?     @relation(fields: [supplierId], references: [id])
  supplierId     String?
  status         ExpenseStatus @default(submitted)
  requestedBy    String
  approvedBy     String?
  rejectedBy     String?
  rejectionNote  String?
  paidBy         String?
  paymentKey     String?       @unique
  incurredAt     DateTime      @default(now())
  approvedAt     DateTime?
  rejectedAt     DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([category, incurredAt])
  @@index([supplierId])
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  number         String              @unique
  idempotencyKey String?             @unique
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  supplierId     String
  status         PurchaseOrderStatus @default(draft)
  location       String
  note           String?
  createdBy      String
  sentAt         DateTime?
  receivedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  items          PurchaseOrderItem[]
  receipts       PurchaseReceipt[]

  @@index([supplierId, createdAt])
  @@index([status, createdAt])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  product         Product       @relation(fields: [productId], references: [id])
  productId       String
  orderedQty      Int
  receivedQty     Int           @default(0)
  unitCost        Int

  @@unique([purchaseOrderId, productId])
  @@index([productId])
}

model PurchaseReceipt {
  id              String        @id @default(cuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  idempotencyKey  String
  actor           String
  payload         Json
  createdAt       DateTime      @default(now())

  @@unique([purchaseOrderId, idempotencyKey])
  @@index([purchaseOrderId, createdAt])
}

// Возврат брака поставщику (RMA). Машина статусов + SLA; просрочка → Risk Center.
model SupplierRma {
  id         String    @id @default(cuid())
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  supplierId String
  imei       String
  defect     String
  status     RmaStatus @default(created)
  sla        DateTime
  resolution String? // repaired | replaced | refunded | rejected — итог для scorecard
  createdAt  DateTime  @default(now())

  @@index([supplierId])
  @@index([imei])
  @@index([status])
}

// Продажа в долг / рассрочка. Долг сверх лимита — через approval (action=debt).
// balance гасится платежами; просрочка (open + dueDate<now) → Risk Center.
model DebtPlan {
  id           String     @id @default(cuid())
  orderId      String
  customerId   String
  principal    Int // исходная сумма долга
  balance      Int // остаток к погашению
  installments Int        @default(1) // число платежей (рассрочка)
  dueDate      DateTime
  status       DebtStatus @default(open)
  createdAt    DateTime   @default(now())

  @@index([customerId])
  @@index([status])
  @@index([orderId])
}

model TradeInDevice {
  id             String   @id @default(cuid())
  customer       Customer @relation(fields: [customerId], references: [id])
  customerId     String // PII: паспорт продавца
  model          String
  grade          Grade
  price          Int
  contractId     String?
  sellerPassport String // защищённое поле + anti-fraud
  imei           String? // anti-fraud: тот же IMEI в скупке И в продаже → risk-флаг

  @@index([customerId])
  @@index([imei])
}

model CourierRun {
  id             String   @id @default(cuid())
  courierId      String
  codTotal       Int // COD не сдан >24ч → Risk
  handedOver     Boolean  @default(false)
  collectedTotal Int      @default(0)
  orders         Order[]
  createdAt      DateTime @default(now())

  @@index([courierId])
  @@index([handedOver])
}

model CourierCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  courierId      String
  orderId        String
  action         String
  payload        Json
  response       Json?
  createdAt      DateTime @default(now())

  @@index([courierId, createdAt])
  @@index([orderId, createdAt])
}

model Approval {
  id        String         @id @default(cuid())
  action    String // discount | refund | write_off | price | debt | delete | stock_adjust | pii
  requester String
  approver  String?
  status    ApprovalStatus @default(requested)
  reason    String
  evidence  Json? // обязательно для high-risk
  createdAt DateTime       @default(now())

  @@index([status])
  @@index([action])
}

// Неизменяемо. Только append. Никаких update/delete. Источник правды.
model AuditEvent {
  id      String   @id @default(cuid())
  type    String // order.* payment.* stock.* approval.* и т.д.
  actor   String
  ts      DateTime @default(now())
  payload Json
  refs    String[] // связанные id (orderId, imei, shiftId…)

  @@index([type])
  @@index([actor])
  @@index([refs], type: Gin) // array-containment (has/hasEvery) needs GIN, not B-tree
}

model Campaign {
  id      String @id @default(cuid())
  segment String
  channel String
  budget  Int
  orders  Int    @default(0)
  revenue Int    @default(0)
  // аудитория фильтруется по Customer.consent
}

model SupportTicket {
  id             String       @id @default(cuid())
  customerId     String // ссылка строкой, без @relation (см. Customer)
  channel        String // web | app | whatsapp | telegram | call | store
  subject        String
  body           String?
  priority       String // normal | high | urgent (эскалация повышает уровень)
  sla            DateTime
  status         TicketStatus @default(new)
  assignee       String?
  idempotencyKey String?      @unique
  createdAt      DateTime     @default(now())

  @@index([customerId])
  @@index([status])
}

// Business buyer profile is customer-owned but intentionally stores customerId
// without a foreign key, matching SupportTicket/WarrantyCase test isolation.
model BusinessBuyerProfile {
  id             String   @id @default(cuid())
  customerId     String   @unique
  companyName    String
  taxId          String
  contactName    String
  email          String?
  billingAddress String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyName])
}

model B2BQuote {
  id              String         @id @default(cuid())
  customerId      String
  status          B2BQuoteStatus @default(requested)
  paymentIntent   String         @default("invoice") // invoice | bank_transfer
  fulfillmentType String         @default("delivery") // delivery | pickup
  deliveryAddress String?
  pickupPoint     String?
  comment         String?
  staffNote       String?
  listTotal       Int
  quotedTotal     Int?
  validUntil      DateTime?
  items           B2BQuoteItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([customerId, createdAt])
  @@index([status, createdAt])
}

model B2BQuoteItem {
  id          String   @id @default(cuid())
  quote       B2BQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String
  sku         String
  name        String
  qty         Int
  listPrice   Int
  targetPrice Int?

  @@index([quoteId])
  @@index([sku])
}

model DeviceProtectionPolicy {
  id             String           @id @default(cuid())
  customerId     String
  orderId        String
  imei           String
  productName    String
  planType       String // accidental_damage | extended_warranty | full_protection
  status         ProtectionStatus @default(requested)
  deviceValue    Int
  premium        Int?
  coverageMonths Int
  staffNote      String?
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@index([imei])
}

// ---------- AUTH ----------
enum OtpPurpose {
  login
}

// One-time login code (phone+OTP). Code stored hashed; short-lived; attempt-capped.
model OtpChallenge {
  id         String     @id @default(cuid())
  phone      String
  codeHash   String
  purpose    OtpPurpose @default(login)
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([phone])
}

// Rotating refresh token, stored as a sha-256 hash and single-use (revoked on
// refresh). customerId is a plain indexed string to avoid coupling the Customer
// model that other modules edit concurrently.
model RefreshToken {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([customerId])
}

// ---------- OUTBOX ----------
enum OutboxStatus {
  pending
  sent
  failed
}

// Transactional outbox for guaranteed-delivery side-effects (notifications,
// webhook follow-ups). Producers write a message in the SAME transaction as the
// business change (invariant #10); a pg-boss relay delivers it with retries.
model OutboxMessage {
  id        String       @id @default(cuid())
  channel   String // sms | email | push | telegram | webhook
  recipient String
  template  String
  payload   Json
  status    OutboxStatus @default(pending)
  attempts  Int          @default(0)
  lastError String?
  createdAt DateTime     @default(now())
  sentAt    DateTime?

  @@index([status])
}

// ---------- STAFF AUTH ----------
// Staff login carries a role in the JWT so dangerous actions are authorized on
// the server (Role Permission Matrix), not trusted from the request body.
model StaffUser {
  id            String      @id @default(cuid())
  username      String      @unique
  passwordHash  String
  role          Role
  active        Boolean     @default(true)
  totpSecret    String?
  totpEnabled   Boolean     @default(false)
  totpLastToken String? // last used TOTP code — single-use guard (anti-replay)
  pushTokens    PushToken[]
  assignedTasks StaffTask[] @relation("StaffTaskAssignee")
  createdTasks  StaffTask[] @relation("StaffTaskCreator")
  courierOrders Order[]     @relation("OrderCourier")
  createdAt     DateTime    @default(now())

  @@index([role])
}

enum StaffTaskStatus {
  open
  in_progress
  completed
  cancelled
}

enum StaffTaskPriority {
  low
  normal
  high
  urgent
}

model StaffTask {
  id          String            @id @default(cuid())
  title       String
  description String?
  status      StaffTaskStatus   @default(open)
  priority    StaffTaskPriority @default(normal)
  assigneeId  String
  assignee    StaffUser         @relation("StaffTaskAssignee", fields: [assigneeId], references: [id])
  createdById String
  createdBy   StaffUser         @relation("StaffTaskCreator", fields: [createdById], references: [id])
  dueAt       DateTime?
  relatedType String?
  relatedId   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  completedAt DateTime?

  @@index([assigneeId, status])
  @@index([dueAt])
}
