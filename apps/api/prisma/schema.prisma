// AliStore — Prisma schema (PostgreSQL)
// Origin: design_handoff_alistore/reference/schema.prisma («API Data Contracts»).
// Faithful to the reference. Two kinds of adaptation applied, both non-behavioral:
//   1. Payment<->CashShift made into a real Prisma relation (reference declared only
//      one side, which fails `prisma validate`).
//   2. @@index added on hot query paths. No field semantics changed.
// Business invariants (see docs/AliStore Business Invariants.md) are enforced in the
// service layer inside transactions, not by the schema alone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS ----------
enum Role {
  seller
  senior_seller
  cashier
  warehouse
  courier
  marketer
  admin
  owner
  franchise
}

enum OrderStatus {
  draft
  created
  awaiting_confirmation
  confirmed
  reserved
  awaiting_payment
  paid
  picking
  packed
  ready_for_pickup
  courier_assigned
  out_for_delivery
  delivered
  completed
  cancelled
  return_requested
  returned
  exchanged
  refunded
}

enum PaymentMethod {
  cash
  card
  qr_mbank
  qr_odengi
  bakai_pos
  obank
  installment
  gift_card
}

enum PaymentStatus {
  pending
  received
  reconciled
  disputed
  refunded
}

enum UnitStatus {
  in_stock
  reserved
  sold
  returned
  in_repair
  written_off
}

enum Grade {
  A
  B
  C
}

enum ApprovalStatus {
  requested
  approved
  rejected
}

enum ReturnStatus {
  requested
  under_review
  approved
  rejected
  processing
  paid
  reconciled
}

enum WarrantyStatus {
  created
  received
  diagnostics
  waiting_supplier
  approved
  rejected
  repaired
  replaced
  closed
}

enum TicketStatus {
  new
  in_progress
  waiting
  resolved
  closed
}

enum RmaStatus {
  created
  shipped
  accepted
  repaired
  replaced
  refunded
  rejected
  closed
}

enum DebtStatus {
  open
  settled
  written_off
}

enum GiftCardStatus {
  active
  redeemed
  cancelled
  expired
}

// ---------- CORE ----------
model Customer {
  id        String          @id @default(cuid())
  phone     String          @unique // PII — маскировать младшим ролям
  name      String
  consent   Boolean         @default(false) // маркетинг только при true
  segments  String[]
  ltv       Int             @default(0)
  identities CustomerIdentity[]
  orders    Order[]
  tradeIns  TradeInDevice[]
  createdAt DateTime        @default(now())
  // SupportTicket ссылается на customerId строкой (как WarrantyCase/DebtPlan) —
  // без @relation, чтобы очистка в тестах не каскадила через FK.
}

model CustomerIdentity {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider    String
  subject     String
  email       String?
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, subject])
  @@index([customerId])
}

model Product {
  id        String              @id @default(cuid())
  sku       String              @unique
  name      String
  price     Int
  cost      Int
  category  String
  attrs     Json
  archived  Boolean             @default(false) // soft-delete: НЕ удалять физически
  units     DeviceUnit[]
  movements InventoryMovement[]

  @@index([category])
  @@index([archived])
}

model ProductReview {
  id           String   @id @default(cuid())
  productId    String
  sku          String
  customerId   String
  customerName String
  orderId      String
  rating       Int
  text         String?
  createdAt    DateTime @default(now())

  @@unique([productId, customerId, orderId])
  @@index([productId])
  @@index([customerId])
  @@index([orderId])
}

model DeviceUnit {
  id        String     @id @default(cuid())
  imei      String     @unique // один IMEI нельзя продать дважды
  product   Product    @relation(fields: [productId], references: [id])
  productId String
  status    UnitStatus @default(in_stock)
  grade     Grade?
  location  String
  orderId   String?
  // повтор IMEI в trade-in + продаже → risk-флаг (проверка на сервере)

  @@index([productId])
  @@index([status])
  @@index([orderId])
}

model Order {
  id         String      @id @default(cuid())
  customer   Customer    @relation(fields: [customerId], references: [id])
  customerId String
  status     OrderStatus @default(draft)
  channel    String // web | app | pos | telegram
  total      Int
  items      OrderItem[]
  payments   Payment[]
  createdAt  DateTime    @default(now())
  // переходы статусов — только через сервис state-machine + запись AuditEvent

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id      String  @id @default(cuid())
  order   Order   @relation(fields: [orderId], references: [id])
  orderId String
  sku     String
  qty     Int
  price   Int
  imei    String?

  @@index([orderId])
}

model Payment {
  id        String        @id @default(cuid())
  order     Order?        @relation(fields: [orderId], references: [id])
  orderId   String?
  amount    Int // отрицательное = возврат
  method    PaymentMethod
  status    PaymentStatus @default(pending)
  shift     CashShift?    @relation(fields: [shiftId], references: [id])
  shiftId   String?
  txnId     String?       @unique // идемпотентность webhook (dedup)
  createdAt DateTime      @default(now())

  @@index([orderId])
  @@index([shiftId])
}

model GiftCard {
  id             String         @id @default(cuid())
  code           String         @unique
  initialBalance Int
  balance        Int
  currency       String         @default("KGS")
  status         GiftCardStatus @default(active)
  customerId     String?
  issuedBy       String
  note           String?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([customerId])
  @@index([status])
}

model CashShift {
  id        String    @id @default(cuid())
  staffId   String
  point     String
  openCash  Int
  closeCash Int?
  diff      Int? // расхождение → approval + Risk
  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  payments  Payment[]
}

model InventoryMovement {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  qty       Int
  type      String // received | moved | write_off | adjust | count
  from      String?
  to        String?
  reason    String?
  createdAt DateTime @default(now())
  // write_off / adjust → owner approval + evidence

  @@index([productId])
  @@index([type])
}

model Reservation {
  id        String   @id @default(cuid())
  orderId   String
  imei      String?
  expiresAt DateTime // зависший резерв → Risk
  active    Boolean  @default(true)

  @@index([orderId])
  @@index([imei])
  @@index([active])
}

model Return {
  id        String       @id @default(cuid())
  orderId   String
  reason    String
  status    ReturnStatus @default(requested)
  refundId  String? // refund → approval, тем же способом
  createdAt DateTime     @default(now())

  @@index([orderId])
  @@index([status])
}

model WarrantyCase {
  id         String         @id @default(cuid())
  imei       String
  customerId String
  problem    String
  status     WarrantyStatus @default(created)
  sla        DateTime
  assignee   String?

  @@index([imei])
  @@index([status])
}

// Поставщик техники. Scorecard считается из связанных RMA.
model Supplier {
  id        String        @id @default(cuid())
  name      String        @unique
  contact   String?
  rmas      SupplierRma[]
  createdAt DateTime      @default(now())
}

// Возврат брака поставщику (RMA). Машина статусов + SLA; просрочка → Risk Center.
model SupplierRma {
  id         String    @id @default(cuid())
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  supplierId String
  imei       String
  defect     String
  status     RmaStatus @default(created)
  sla        DateTime
  resolution String? // repaired | replaced | refunded | rejected — итог для scorecard
  createdAt  DateTime  @default(now())

  @@index([supplierId])
  @@index([imei])
  @@index([status])
}

// Продажа в долг / рассрочка. Долг сверх лимита — через approval (action=debt).
// balance гасится платежами; просрочка (open + dueDate<now) → Risk Center.
model DebtPlan {
  id           String     @id @default(cuid())
  orderId      String
  customerId   String
  principal    Int // исходная сумма долга
  balance      Int // остаток к погашению
  installments Int        @default(1) // число платежей (рассрочка)
  dueDate      DateTime
  status       DebtStatus @default(open)
  createdAt    DateTime   @default(now())

  @@index([customerId])
  @@index([status])
  @@index([orderId])
}

model TradeInDevice {
  id             String   @id @default(cuid())
  customer       Customer @relation(fields: [customerId], references: [id])
  customerId     String // PII: паспорт продавца
  model          String
  grade          Grade
  price          Int
  contractId     String?
  sellerPassport String // защищённое поле + anti-fraud
  imei           String? // anti-fraud: тот же IMEI в скупке И в продаже → risk-флаг

  @@index([customerId])
  @@index([imei])
}

model CourierRun {
  id         String   @id @default(cuid())
  courierId  String
  codTotal   Int // COD не сдан >24ч → Risk
  handedOver Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([courierId])
  @@index([handedOver])
}

model Approval {
  id        String         @id @default(cuid())
  action    String // discount | refund | write_off | price | debt | delete | stock_adjust | pii
  requester String
  approver  String?
  status    ApprovalStatus @default(requested)
  reason    String
  evidence  Json? // обязательно для high-risk
  createdAt DateTime       @default(now())

  @@index([status])
  @@index([action])
}

// Неизменяемо. Только append. Никаких update/delete. Источник правды.
model AuditEvent {
  id      String   @id @default(cuid())
  type    String // order.* payment.* stock.* approval.* и т.д.
  actor   String
  ts      DateTime @default(now())
  payload Json
  refs    String[] // связанные id (orderId, imei, shiftId…)

  @@index([type])
  @@index([actor])
  @@index([refs])
}

model Campaign {
  id      String @id @default(cuid())
  segment String
  channel String
  budget  Int
  orders  Int    @default(0)
  revenue Int    @default(0)
  // аудитория фильтруется по Customer.consent
}

model SupportTicket {
  id         String       @id @default(cuid())
  customerId String // ссылка строкой, без @relation (см. Customer)
  channel    String // web | app | whatsapp | telegram | call | store
  subject    String
  body       String?
  priority   String // normal | high | urgent (эскалация повышает уровень)
  sla        DateTime
  status     TicketStatus @default(new)
  assignee   String?
  createdAt  DateTime     @default(now())

  @@index([customerId])
  @@index([status])
}

// ---------- AUTH ----------
enum OtpPurpose {
  login
}

// One-time login code (phone+OTP). Code stored hashed; short-lived; attempt-capped.
model OtpChallenge {
  id         String     @id @default(cuid())
  phone      String
  codeHash   String
  purpose    OtpPurpose @default(login)
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([phone])
}

// Rotating refresh token, stored as a sha-256 hash and single-use (revoked on
// refresh). customerId is a plain indexed string to avoid coupling the Customer
// model that other modules edit concurrently.
model RefreshToken {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([customerId])
}

// ---------- OUTBOX ----------
enum OutboxStatus {
  pending
  sent
  failed
}

// Transactional outbox for guaranteed-delivery side-effects (notifications,
// webhook follow-ups). Producers write a message in the SAME transaction as the
// business change (invariant #10); a pg-boss relay delivers it with retries.
model OutboxMessage {
  id        String       @id @default(cuid())
  channel   String // sms | email | push | telegram | webhook
  recipient String
  template  String
  payload   Json
  status    OutboxStatus @default(pending)
  attempts  Int          @default(0)
  lastError String?
  createdAt DateTime     @default(now())
  sentAt    DateTime?

  @@index([status])
}

// ---------- STAFF AUTH ----------
// Staff login carries a role in the JWT so dangerous actions are authorized on
// the server (Role Permission Matrix), not trusted from the request body.
model StaffUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role
  active       Boolean  @default(true)
  totpSecret   String?
  totpEnabled  Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([role])
}
