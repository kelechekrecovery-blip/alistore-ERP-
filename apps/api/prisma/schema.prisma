  @@index([status, createdAt])
  @@index([periodStart, periodEnd, point])
}

model FinanceSettlementLine {
  id               String                      @id @default(cuid())
  run              FinanceSettlementRun        @relation(fields: [runId], references: [id], onDelete: Restrict)
  runId            String
  sourceType       FinanceSettlementSourceType
