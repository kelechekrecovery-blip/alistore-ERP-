// AliStore — Prisma schema (PostgreSQL)
// Origin: design_handoff_alistore/reference/schema.prisma («API Data Contracts»).
// Faithful to the reference. Two kinds of adaptation applied, both non-behavioral:
//   1. Payment<->CashShift made into a real Prisma relation (reference declared only
//      one side, which fails `prisma validate`).
//   2. @@index added on hot query paths. No field semantics changed.
// Business invariants (see docs/AliStore Business Invariants.md) are enforced in the
// service layer inside transactions, not by the schema alone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS ----------
enum Role {
  seller
  senior_seller
  cashier
  warehouse
  courier
  marketer
  admin
  owner
  franchise
}

enum OrderStatus {
  draft
  created
  awaiting_confirmation
  confirmed
  reserved
  awaiting_payment
  paid
  picking
  packed
  ready_for_pickup
  courier_assigned
  out_for_delivery
  delivered
  completed
  cancelled
  return_requested
  returned
  exchanged
  refunded
}

enum PaymentMethod {
  cash
  card
  qr_mbank
  qr_odengi
  bakai_pos
  obank
  installment
  gift_card
}

enum PaymentStatus {
  pending
  received
  reconciled
  disputed
  refunded
}

enum UnitStatus {
  in_stock
  reserved
  sold
  returned
  in_repair
  written_off
}

enum StockTrackingMode {
  serialized
  quantity
}

enum ConsignmentStatus {
  active
  sold
  settled
  withdrawn
}

enum ConsignmentPayoutStatus {
  created
  paid
  cancelled
}

enum ConsignmentAdjustmentStatus {
  open
  settled
}

enum Grade {
  A
  B
  C
}

enum ApprovalStatus {
  requested
  approved
  rejected
}

enum ReturnStatus {
  requested
  under_review
  approved
  rejected
  processing
  paid
  reconciled
}

enum WarrantyStatus {
  created
  received
  diagnostics
  waiting_supplier
  approved
  rejected
  repaired
  replaced
  closed
}

enum TicketStatus {
  new
  in_progress
  waiting
  resolved
  closed
}

enum RmaStatus {
  created
  shipped
  accepted
  repaired
  replaced
  refunded
  rejected
  closed
}

enum DebtStatus {
  open
  settled
  written_off
}

enum GiftCardStatus {
  active
  redeemed
  cancelled
  expired
}

enum B2BQuoteStatus {
  requested
  reviewing
  quoted
  accepted
  rejected
}

enum ProtectionStatus {
  requested
  reviewing
  offered
  active
  rejected
  cancelled
}

enum PurchaseOrderStatus {
  draft
  sent
  receiving
  received
  cancelled
}

enum ExpenseStatus {
  submitted
  approved
  rejected
  paid
}

enum HrAbsenceType {
  annual_leave
  sick_leave
  unpaid_leave
  other
}

enum HrAbsenceStatus {
  requested
  approved
  rejected
  cancelled
}

enum HrPayrollStatus {
  posted
  paid
}

// ---------- CORE ----------
model Customer {
  id             String               @id @default(cuid())
  phone          String               @unique // PII — маскировать младшим ролям
  name           String
  consent        Boolean              @default(false) // маркетинг только при true
  segments       String[]
  ltv            Int                  @default(0)
  identities     CustomerIdentity[]
  pushTokens     PushToken[]
  addresses      CustomerAddress[]
  preferences    CustomerPreferences?
  loyaltyEntries LoyaltyEntry[]
  coupons        CustomerCoupon[]
  orders         Order[]
  tradeIns       TradeInDevice[]
  createdAt      DateTime             @default(now())
  // SupportTicket ссылается на customerId строкой (как WarrantyCase/DebtPlan) —
  // без @relation, чтобы очистка в тестах не каскадила через FK.
}

model CustomerAddress {
  id             String   @id @default(cuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title          String
  text           String
  comment        String?
  isPrimary      Boolean  @default(false)
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId, isPrimary])
}

model CustomerPreferences {
  customerId String   @id
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  push       Boolean  @default(true)
  whatsapp   Boolean  @default(true)
  service    Boolean  @default(true)
  promos     Boolean  @default(false)
  updatedAt  DateTime @updatedAt
}

model LoyaltyEntry {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  kind       String    @default("adjustment") // earn | redeem | refund_restore | refund_clawback | adjustment
  label      String
  amount     Int
  sourceRef  String?   @unique
  orderId    String?
  paymentId  String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([customerId, createdAt])
  @@index([orderId])
  @@index([paymentId])
}

model CustomerCoupon {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title      String
  code       String
  valueLabel String
  expiresAt  DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@unique([customerId, code])
  @@index([customerId, active])
}

model CustomerIdentity {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider    String
  subject     String
  email       String?
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, subject])
  @@index([customerId])
}

model PushToken {
  id         String     @id @default(cuid())
  token      String     @unique
  platform   String
  deviceId   String
  appScope   String     @default("anonymous") // anonymous | customer | staff
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staffId    String?
  staff      StaffUser? @relation(fields: [staffId], references: [id], onDelete: Cascade)
  enabled    Boolean    @default(true)
  lastSeenAt DateTime   @default(now())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([customerId, enabled])
  @@index([staffId, enabled])
  @@index([platform])
}

model Product {
  id                      String                    @id @default(cuid())
  sku                     String                    @unique
  barcode                 String?                   @unique
  variantGroup            String?
  name                    String
  price                   Int
  cost                    Int
  category                String
  trackingMode            StockTrackingMode         @default(serialized)
  attrs                   Json
  archived                Boolean                   @default(false) // soft-delete: НЕ удалять физически
  updatedAt               DateTime                  @default(now()) @updatedAt
  units                   DeviceUnit[]
  movements               InventoryMovement[]
  balances                InventoryBalance[]
  quantityAllocations     OrderQuantityAllocation[]
  purchaseOrderItems      PurchaseOrderItem[]
  bundleComponents        ProductBundleComponent[]  @relation("BundleProduct")
  includedInBundles       ProductBundleComponent[]  @relation("BundleComponentProduct")
  bundleAllocations       OrderBundleAllocation[]
  consignmentItems        ConsignmentItem[]
  quantityConsignmentLots QuantityConsignmentLot[]

  @@index([category])
  @@index([variantGroup])
  @@index([archived])
  @@index([updatedAt])
}

model InventoryBalance {
  id                      String                    @id @default(cuid())
  product                 Product                   @relation(fields: [productId], references: [id])
  productId               String
  location                String
  onHand                  Int                       @default(0)
  reserved                Int                       @default(0)
  updatedAt               DateTime                  @default(now()) @updatedAt
  allocations             OrderQuantityAllocation[]
  quantityConsignmentLots QuantityConsignmentLot[]

  @@unique([productId, location])
  @@index([location])
  @@index([updatedAt])
}

model ProductBundleComponent {
  id                 String  @id @default(cuid())
  bundleProduct      Product @relation("BundleProduct", fields: [bundleProductId], references: [id])
  bundleProductId    String
  componentProduct   Product @relation("BundleComponentProduct", fields: [componentProductId], references: [id])
  componentProductId String
  qty                Int

  @@unique([bundleProductId, componentProductId])
  @@index([componentProductId])
}

model ProductReview {
  id           String   @id @default(cuid())
  productId    String
  sku          String
  customerId   String
  customerName String
  orderId      String
  rating       Int
  text         String?
  createdAt    DateTime @default(now())

  @@unique([productId, customerId, orderId])
  @@index([productId])
  @@index([customerId])
  @@index([orderId])
}

model DeviceUnit {
  id              String           @id @default(cuid())
  imei            String           @unique // один IMEI нельзя продать дважды
  product         Product          @relation(fields: [productId], references: [id])
  productId       String
  status          UnitStatus       @default(in_stock)
  grade           Grade?
  location        String
  orderId         String?
  updatedAt       DateTime         @default(now()) @updatedAt
  consignmentItem ConsignmentItem?
  // повтор IMEI в trade-in + продаже → risk-флаг (проверка на сервере)

  @@index([productId])
  @@index([status])
  @@index([orderId])
  @@index([updatedAt])
}

model Order {
  id                       String                          @id @default(cuid())
  idempotencyKey           String?                         @unique
  isDemo                   Boolean                         @default(false)
  customer                 Customer                        @relation(fields: [customerId], references: [id])
  customerId               String
  status                   OrderStatus                     @default(draft)
  channel                  String // web | app | mobile | pos | telegram
  fulfillmentType          String                          @default("pickup") // pickup | courier | express | store
  pickupPoint              String?
  deliveryAddress          String?
  deliverySlot             String?
  deliveryZoneId           String?
  deliveryZone             DeliveryZone?                   @relation(fields: [deliveryZoneId], references: [id])
  deliverySlotId           String?
  logisticsSlot            DeliverySlot?                   @relation(fields: [deliverySlotId], references: [id])
  courierId                String?
  courier                  StaffUser?                      @relation("OrderCourier", fields: [courierId], references: [id])
  courierRunId             String?
  courierRun               CourierRun?                     @relation(fields: [courierRunId], references: [id])
  pickupCode               String?
  subtotal                 Int                             @default(0)
  deliveryFee              Int                             @default(0)
  promoCode                String?
  promoDiscount            Int                             @default(0)
  loyaltyRedeemed          Int                             @default(0)
  loyaltyEarned            Int                             @default(0)
  total                    Int
  items                    OrderItem[]
  bundleAllocations        OrderBundleAllocation[]
  quantityAllocations      OrderQuantityAllocation[]
  consignmentSales         ConsignmentItem[]               @relation("ConsignmentSaleOrder")
  quantityConsignmentSales QuantityConsignmentAllocation[] @relation("QuantityConsignmentSaleOrder")
  payments                 Payment[]
  returns                  Return[]
  createdAt                DateTime                        @default(now())
  // переходы статусов — только через сервис state-machine + запись AuditEvent

  @@index([customerId])
  @@index([isDemo, createdAt])
  @@index([status])
  @@index([fulfillmentType, status])
  @@index([pickupPoint, status])
  @@index([courierId, status])
  @@index([courierRunId])
  @@index([deliveryZoneId, status])
  @@index([deliverySlotId, status])
}

model DeliveryZone {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  fee            Int
  etaMinMinutes  Int
  etaMaxMinutes  Int
  active         Boolean        @default(true)
  createdBy      String
  idempotencyKey String         @unique
  slots          DeliverySlot[]
  orders         Order[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model DeliverySlot {
  id             String       @id @default(cuid())
  zone           DeliveryZone @relation(fields: [zoneId], references: [id])
  zoneId         String
  startsAt       DateTime
  endsAt         DateTime
  capacity       Int
  active         Boolean      @default(true)
  createdBy      String
  idempotencyKey String       @unique
  orders         Order[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([zoneId, startsAt, endsAt])
  @@index([startsAt, active])
}

model ConsignmentItem {
  id               String             @id @default(cuid())
  idempotencyKey   String             @unique
  unit             DeviceUnit         @relation(fields: [unitId], references: [id])
  unitId           String             @unique
  product          Product            @relation(fields: [productId], references: [id])
  productId        String
  ownerName        String
  ownerContact     String?
  commissionBps    Int
  status           ConsignmentStatus  @default(active)
  saleOrder        Order?             @relation("ConsignmentSaleOrder", fields: [saleOrderId], references: [id])
  saleOrderId      String?
  salePrice        Int?
  commissionAmount Int?
  ownerAmount      Int?
  soldAt           DateTime?
  payout           ConsignmentPayout? @relation(fields: [payoutId], references: [id])
  payoutId         String?
  createdBy        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([ownerName, ownerContact])
  @@index([saleOrderId])
  @@index([payoutId])
}

model ConsignmentPayout {
  id                  String                          @id @default(cuid())
  idempotencyKey      String                          @unique
  ownerName           String
  ownerContact        String?
  grossAmount         Int
  commissionAmount    Int
  ownerAmount         Int
  status              ConsignmentPayoutStatus         @default(created)
  paymentKey          String?                         @unique
  createdBy           String
  paidBy              String?
  paidAt              DateTime?
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  items               ConsignmentItem[]
  quantityAllocations QuantityConsignmentAllocation[]

  @@index([status, createdAt])
  @@index([ownerName, ownerContact])
}

model QuantityConsignmentLot {
  id             String                          @id @default(cuid())
  idempotencyKey String                          @unique
  product        Product                         @relation(fields: [productId], references: [id])
  productId      String
  balance        InventoryBalance                @relation(fields: [balanceId], references: [id])
  balanceId      String
  location       String
  ownerName      String
  ownerContact   String?
  commissionBps  Int
  receivedQty    Int
  availableQty   Int
  reservedQty    Int                             @default(0)
  createdBy      String
  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt
  allocations    QuantityConsignmentAllocation[]

  @@index([productId, location, createdAt])
  @@index([balanceId, availableQty])
  @@index([ownerName, ownerContact])
}

model QuantityConsignmentAllocation {
  id                        String                  @id @default(cuid())
  lot                       QuantityConsignmentLot  @relation(fields: [lotId], references: [id])
  lotId                     String
  orderQuantityAllocation   OrderQuantityAllocation @relation(fields: [orderQuantityAllocationId], references: [id])
  orderQuantityAllocationId String
  saleOrder                 Order?                  @relation("QuantityConsignmentSaleOrder", fields: [saleOrderId], references: [id])
  saleOrderId               String?
  qty                       Int
  returnedQty               Int                     @default(0)
  status                    ConsignmentStatus       @default(active)
  salePrice                 Int?
  commissionAmount          Int?
  ownerAmount               Int?
  returnedSaleAmount        Int                     @default(0)
  returnedCommissionAmount  Int                     @default(0)
  returnedOwnerAmount       Int                     @default(0)
  soldAt                    DateTime?
  returnedAt                DateTime?
  payout                    ConsignmentPayout?      @relation(fields: [payoutId], references: [id])
  payoutId                  String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  @@unique([orderQuantityAllocationId, lotId])
  @@index([saleOrderId, status])
  @@index([payoutId])
  @@index([lotId, status])
}

model QuantityConsignmentAdjustment {
  id           String                      @id @default(cuid())
  returnId     String
  allocationId String
  payoutId     String
  ownerName    String
  ownerContact String?
  amount       Int
  reason       String
  status       ConsignmentAdjustmentStatus @default(open)
  createdBy    String
  settledBy    String?
  settledAt    DateTime?
  createdAt    DateTime                    @default(now())

  @@unique([returnId, allocationId])
  @@index([status, createdAt])
  @@index([payoutId])
  @@index([ownerName, ownerContact])
}

model ConsignmentAdjustment {
  id           String                      @id @default(cuid())
  returnId     String
  itemId       String
  payoutId     String
  ownerName    String
  ownerContact String?
  amount       Int
  reason       String
  status       ConsignmentAdjustmentStatus @default(open)
  createdBy    String
  settledBy    String?
  settledAt    DateTime?
  createdAt    DateTime                    @default(now())

  @@unique([returnId, itemId])
  @@index([status, createdAt])
  @@index([payoutId])
  @@index([ownerName, ownerContact])
}

model OrderQuantityAllocation {
  id                     String                          @id @default(cuid())
  order                  Order                           @relation(fields: [orderId], references: [id])
  orderId                String
  orderItemId            String
  product                Product                         @relation(fields: [productId], references: [id])
  productId              String
  balance                InventoryBalance                @relation(fields: [balanceId], references: [id])
  balanceId              String
  sku                    String
  qty                    Int
  active                 Boolean                         @default(true)
  consumedAt             DateTime?
  returnedQty            Int                             @default(0)
  createdAt              DateTime                        @default(now())
  reservation            Reservation?
  consignmentAllocations QuantityConsignmentAllocation[]

  @@index([orderId, active])
  @@index([productId])
  @@index([balanceId])
}

model OrderBundleAllocation {
  id                 String   @id @default(cuid())
  order              Order    @relation(fields: [orderId], references: [id])
  orderId            String
  orderItemId        String
  bundleSku          String
  componentProduct   Product  @relation(fields: [componentProductId], references: [id])
  componentProductId String
  componentSku       String
  imei               String   @unique
  createdAt          DateTime @default(now())

  @@index([orderId])
  @@index([orderItemId])
  @@index([componentProductId])
}

model OrderItem {
  id          String       @id @default(cuid())
  order       Order        @relation(fields: [orderId], references: [id])
  orderId     String
  sku         String
  qty         Int
  price       Int
  imei        String?
  returnItems ReturnItem[]

  @@index([orderId])
}

model Payment {
  id        String        @id @default(cuid())
  order     Order?        @relation(fields: [orderId], references: [id])
  orderId   String?
  amount    Int // отрицательное = возврат
  method    PaymentMethod
  status    PaymentStatus @default(pending)
  shift     CashShift?    @relation(fields: [shiftId], references: [id])
  shiftId   String?
  txnId     String?       @unique // идемпотентность webhook (dedup)
  createdAt DateTime      @default(now())

  @@index([orderId])
  @@index([shiftId])
  @@index([status, createdAt]) // dashboards/KPI/payroll filter by status + date window
}

model OnlinePaymentIntentCommand {
  id             String        @id @default(cuid())
  idempotencyKey String        @unique
  customerId     String
  orderId        String
  method         PaymentMethod
  amount         Int
  returnUrl      String?
  response       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([customerId, createdAt])
  @@index([orderId])
}

model GiftCard {
  id             String         @id @default(cuid())
  code           String         @unique
  initialBalance Int
  balance        Int
  currency       String         @default("KGS")
  status         GiftCardStatus @default(active)
  customerId     String?
  issuedBy       String
  note           String?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([customerId])
  @@index([status])
}

model CashShift {
  id                  String    @id @default(cuid())
  staffId             String
  point               String
  openCash            Int
  closeCash           Int?
  closeReason         String?
  openIdempotencyKey  String?   @unique
  closeIdempotencyKey String?   @unique
  diff                Int? // расхождение → approval + Risk
  openedAt            DateTime  @default(now())
  closedAt            DateTime?
  payments            Payment[]

  @@index([staffId, closedAt]) // currentOpen() lookup on every POS sale
  @@index([diff, closedAt]) // Risk Center: closed shifts with a discrepancy
}

model CashShiftHandover {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  fromShiftId    String   @unique
  toShiftId      String   @unique
  fromStaffId    String
  toStaffId      String
  point          String
  expectedCash   Int
  countedCash    Int
  diff           Int
  reason         String?
  createdBy      String
  createdAt      DateTime @default(now())

  @@index([point, createdAt])
  @@index([toStaffId, createdAt])
}

model InventoryMovement {
  id             String   @id @default(cuid())
  idempotencyKey String?  @unique
  product        Product  @relation(fields: [productId], references: [id])
  productId      String
  qty            Int
  type           String // received | moved | write_off | adjust | count
  from           String?
  to             String?
  reason         String?
  createdAt      DateTime @default(now())
  // write_off / adjust → owner approval + evidence

  @@index([productId])
  @@index([type])
}

model Reservation {
  id                   String                   @id @default(cuid())
  orderId              String
  imei                 String?
  quantityAllocationId String?                  @unique
  quantityAllocation   OrderQuantityAllocation? @relation(fields: [quantityAllocationId], references: [id])
  expiresAt            DateTime // зависший резерв → Risk
  active               Boolean                  @default(true)

  @@index([orderId])
  @@index([imei])
  @@index([active])
}

model Return {
  id              String       @id @default(cuid())
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String
  reason          String
  status          ReturnStatus @default(requested)
  refundId        String? // refund → approval, тем же способом
  refundAmount    Int          @default(0)
  isFullOrder     Boolean      @default(true)
  idempotencyKey  String?      @unique
  restockLocation String?
  restockedAt     DateTime?
  createdAt       DateTime     @default(now())
  items           ReturnItem[]

  @@index([orderId])
  @@index([status])
}

model ReturnItem {
  id           String    @id @default(cuid())
  return       Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  returnId     String
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId  String
  qty          Int
  refundAmount Int
  createdAt    DateTime  @default(now())

  @@unique([returnId, orderItemId])
  @@index([orderItemId])
}

model WarrantyCase {
  id         String         @id @default(cuid())
  imei       String
  customerId String
  problem    String
  status     WarrantyStatus @default(created)
  sla        DateTime
  assignee   String?
  workOrder  ServiceWorkOrder?

  @@index([imei])
  @@index([status])
}

model ServiceWorkOrder {
  id                 String                    @id @default(cuid())
  warrantyCase       WarrantyCase              @relation(fields: [warrantyCaseId], references: [id], onDelete: Cascade)
  warrantyCaseId     String                    @unique
  technicianId       String?
  diagnosticSummary String?
  diagnosticFee      Int                       @default(0)
  estimateAmount     Int?
  estimatePreparedAt DateTime?
  estimateApprovedAt DateTime?
  estimateApprovedBy String?
  createdBy          String
  commands           ServiceWorkOrderCommand[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([technicianId, createdAt])
  @@index([estimateApprovedAt, createdAt])
}

model ServiceWorkOrderCommand {
  id             String           @id @default(cuid())
  idempotencyKey String           @unique
  workOrder      ServiceWorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  workOrderId    String
  action         String
  request        Json
  response       Json
  createdAt      DateTime         @default(now())

  @@index([workOrderId, createdAt])
}

model WarrantyOpenCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  customerId     String
  imei           String
  problem        String
  warrantyCaseId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId, createdAt])
  @@index([imei])
}

// Поставщик техники. Scorecard считается из связанных RMA.
model Supplier {
  id             String          @id @default(cuid())
  name           String          @unique
  contact        String?
  rmas           SupplierRma[]
  purchaseOrders PurchaseOrder[]
  expenses       Expense[]
  createdAt      DateTime        @default(now())
}

model Expense {
  id             String        @id @default(cuid())
  idempotencyKey String        @unique
  category       String
  description    String
  amount         Int
  point          String?
  supplier       Supplier?     @relation(fields: [supplierId], references: [id])
  supplierId     String?
  status         ExpenseStatus @default(submitted)
  requestedBy    String
  approvedBy     String?
  rejectedBy     String?
  rejectionNote  String?
  paidBy         String?
  paymentKey     String?       @unique
  incurredAt     DateTime      @default(now())
  approvedAt     DateTime?
  rejectedAt     DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([category, incurredAt])
  @@index([supplierId])
}

model FinanceBudget {
  id        String   @id @default(cuid())
  period    String
  category  String
  point     String   @default("")
  amount    Int
  version   Int      @default(1)
  createdBy String
  updatedBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([period, category, point])
  @@index([period, point])
}

model FinanceBudgetCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  period         String
  category       String
  point          String
  amount         Int
  budgetId       String
  response       Json
  createdAt      DateTime @default(now())

  @@index([period, point, createdAt])
  @@index([budgetId])
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  number         String              @unique
  idempotencyKey String?             @unique
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  supplierId     String
  status         PurchaseOrderStatus @default(draft)
  location       String
  note           String?
  createdBy      String
  sentAt         DateTime?
  receivedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  items          PurchaseOrderItem[]
  receipts       PurchaseReceipt[]

  @@index([supplierId, createdAt])
  @@index([status, createdAt])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  product         Product       @relation(fields: [productId], references: [id])
  productId       String
  orderedQty      Int
  receivedQty     Int           @default(0)
  unitCost        Int

  @@unique([purchaseOrderId, productId])
  @@index([productId])
}

model PurchaseReceipt {
  id              String        @id @default(cuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  idempotencyKey  String
  actor           String
  payload         Json
  createdAt       DateTime      @default(now())

  @@unique([purchaseOrderId, idempotencyKey])
  @@index([purchaseOrderId, createdAt])
}

// Возврат брака поставщику (RMA). Машина статусов + SLA; просрочка → Risk Center.
model SupplierRma {
  id         String    @id @default(cuid())
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  supplierId String
  imei       String
  defect     String
  status     RmaStatus @default(created)
  sla        DateTime
  resolution String? // repaired | replaced | refunded | rejected — итог для scorecard
  createdAt  DateTime  @default(now())

  @@index([supplierId])
  @@index([imei])
  @@index([status])
}

// Продажа в долг / рассрочка. Долг сверх лимита — через approval (action=debt).
// balance гасится платежами; просрочка (open + dueDate<now) → Risk Center.
model DebtPlan {
  id           String     @id @default(cuid())
  orderId      String
  customerId   String
  principal    Int // исходная сумма долга
  balance      Int // остаток к погашению
  installments Int        @default(1) // число платежей (рассрочка)
  dueDate      DateTime
  status       DebtStatus @default(open)
  createdAt    DateTime   @default(now())

  @@index([customerId])
  @@index([status])
  @@index([orderId])
}

model TradeInDevice {
  id             String   @id @default(cuid())
  customer       Customer @relation(fields: [customerId], references: [id])
  customerId     String // PII: паспорт продавца
  model          String
  grade          Grade
  price          Int
  contractId     String?
  sellerPassport String // защищённое поле + anti-fraud
  imei           String? // anti-fraud: тот же IMEI в скупке И в продаже → risk-флаг

  @@index([customerId])
  @@index([imei])
}

model CourierRun {
  id                     String   @id @default(cuid())
  courierId              String
  codTotal               Int // COD не сдан >24ч → Risk
  handedOver             Boolean  @default(false)
  collectedTotal         Int      @default(0)
  handoverIdempotencyKey String?  @unique
  handoverAmount         Int?
  handoverReason         String?
  orders                 Order[]
  createdAt              DateTime @default(now())

  @@index([courierId])
  @@index([handedOver])
}

model CourierCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  courierId      String
  orderId        String
  action         String
  payload        Json
  response       Json?
  createdAt      DateTime @default(now())

  @@index([courierId, createdAt])
  @@index([orderId, createdAt])
}

model Approval {
  id        String         @id @default(cuid())
  action    String // discount | refund | write_off | price | debt | delete | stock_adjust | pii
  requester String
  approver  String?
  status    ApprovalStatus @default(requested)
  reason    String
  evidence  Json? // обязательно для high-risk
  createdAt DateTime       @default(now())

  @@index([status])
  @@index([action])
}

// Неизменяемо. Только append. Никаких update/delete. Источник правды.
model AuditEvent {
  id      String   @id @default(cuid())
  type    String // order.* payment.* stock.* approval.* и т.д.
  actor   String
  ts      DateTime @default(now())
  payload Json
  refs    String[] // связанные id (orderId, imei, shiftId…)

  @@index([type])
  @@index([actor])
  @@index([refs], type: Gin) // array-containment (has/hasEvery) needs GIN, not B-tree
}

model Campaign {
  id      String @id @default(cuid())
  segment String
  channel String
  budget  Int
  orders  Int    @default(0)
  revenue Int    @default(0)
  // аудитория фильтруется по Customer.consent
}

model SupportTicket {
  id             String       @id @default(cuid())
  customerId     String // ссылка строкой, без @relation (см. Customer)
  channel        String // web | app | whatsapp | telegram | call | store
  subject        String
  body           String?
  priority       String // normal | high | urgent (эскалация повышает уровень)
  sla            DateTime
  status         TicketStatus @default(new)
  assignee       String?
  idempotencyKey String?      @unique
  createdAt      DateTime     @default(now())

  @@index([customerId])
  @@index([status])
}

// Business buyer profile is customer-owned but intentionally stores customerId
// without a foreign key, matching SupportTicket/WarrantyCase test isolation.
model BusinessBuyerProfile {
  id             String   @id @default(cuid())
  customerId     String   @unique
  companyName    String
  taxId          String
  contactName    String
  email          String?
  billingAddress String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyName])
}

model B2BQuote {
  id              String         @id @default(cuid())
  customerId      String
  status          B2BQuoteStatus @default(requested)
  paymentIntent   String         @default("invoice") // invoice | bank_transfer
  fulfillmentType String         @default("delivery") // delivery | pickup
  deliveryAddress String?
  pickupPoint     String?
  comment         String?
  staffNote       String?
  listTotal       Int
  quotedTotal     Int?
  validUntil      DateTime?
  items           B2BQuoteItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([customerId, createdAt])
  @@index([status, createdAt])
}

model B2BQuoteItem {
  id          String   @id @default(cuid())
  quote       B2BQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String
  sku         String
  name        String
  qty         Int
  listPrice   Int
  targetPrice Int?

  @@index([quoteId])
  @@index([sku])
}

model DeviceProtectionPolicy {
  id             String           @id @default(cuid())
  customerId     String
  orderId        String
  imei           String
  productName    String
  planType       String // accidental_damage | extended_warranty | full_protection
  status         ProtectionStatus @default(requested)
  deviceValue    Int
  premium        Int?
  coverageMonths Int
  staffNote      String?
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@index([imei])
}

// ---------- AUTH ----------
enum OtpPurpose {
  login
}

// One-time login code (phone+OTP). Code stored hashed; short-lived; attempt-capped.
model OtpChallenge {
  id         String     @id @default(cuid())
  phone      String
  codeHash   String
  purpose    OtpPurpose @default(login)
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([phone])
}

// Rotating refresh token, stored as a sha-256 hash and single-use (revoked on
// refresh). customerId is a plain indexed string to avoid coupling the Customer
// model that other modules edit concurrently.
model RefreshToken {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([customerId])
}

// ---------- OUTBOX ----------
enum OutboxStatus {
  pending
  sent
  failed
}

// Transactional outbox for guaranteed-delivery side-effects (notifications,
// webhook follow-ups). Producers write a message in the SAME transaction as the
// business change (invariant #10); a pg-boss relay delivers it with retries.
model OutboxMessage {
  id        String       @id @default(cuid())
  channel   String // sms | email | push | telegram | webhook
  recipient String
  template  String
  payload   Json
  status    OutboxStatus @default(pending)
  attempts  Int          @default(0)
  lastError String?
  createdAt DateTime     @default(now())
  sentAt    DateTime?

  @@index([status])
}

// ---------- STAFF AUTH ----------
// Staff login carries a role in the JWT so dangerous actions are authorized on
// the server (Role Permission Matrix), not trusted from the request body.
model StaffUser {
  id             String          @id @default(cuid())
  username       String          @unique
  passwordHash   String
  role           Role
  active         Boolean         @default(true)
  totpSecret     String?
  totpEnabled    Boolean         @default(false)
  totpLastToken  String? // last used TOTP code — single-use guard (anti-replay)
  pushTokens     PushToken[]
  assignedTasks  StaffTask[]     @relation("StaffTaskAssignee")
  createdTasks   StaffTask[]     @relation("StaffTaskCreator")
  courierOrders  Order[]         @relation("OrderCourier")
  hrSchedules    HrSchedule[]
  hrAttendances  HrAttendance[]
  hrAbsences     HrAbsence[]
  hrPayrollLines HrPayrollLine[]
  createdAt      DateTime        @default(now())

  @@index([role])
}

model HrSchedule {
  id             String        @id @default(cuid())
  staff          StaffUser     @relation(fields: [staffId], references: [id])
  staffId        String
  point          String
  shiftDate      DateTime      @db.Date
  startsAt       DateTime
  endsAt         DateTime
  createdBy      String
  idempotencyKey String        @unique
  attendance     HrAttendance?
  cancelledAt    DateTime?
  cancelledBy    String?
  cancelReason   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([staffId, shiftDate])
  @@index([point, shiftDate])
}

model HrScheduleCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  scheduleId     String
  action         String
  request        Json
  response       Json
  createdAt      DateTime @default(now())

  @@index([scheduleId, createdAt])
}

model HrAttendance {
  id           String     @id @default(cuid())
  schedule     HrSchedule @relation(fields: [scheduleId], references: [id])
  scheduleId   String     @unique
  staff        StaffUser  @relation(fields: [staffId], references: [id])
  staffId      String
  point        String
  checkedInAt  DateTime
  checkedOutAt DateTime?
  checkInKey   String     @unique
  checkOutKey  String?    @unique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([staffId, checkedInAt])
  @@index([point, checkedInAt])
}

model HrAbsence {
  id             String          @id @default(cuid())
  staff          StaffUser       @relation(fields: [staffId], references: [id])
  staffId        String
  type           HrAbsenceType
  startsOn       DateTime        @db.Date
  endsOn         DateTime        @db.Date
  reason         String?
  status         HrAbsenceStatus @default(requested)
  createdBy      String
  decidedBy      String?
  decidedAt      DateTime?
  decisionNote   String?
  idempotencyKey String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([staffId, startsOn, endsOn])
  @@index([status, startsOn])
}

model HrPayrollRun {
  id                   String          @id @default(cuid())
  period               String
  point                String
  status               HrPayrollStatus @default(posted)
  baseAmount           Int
  commissionBps        Int
  latePenaltyPerMinute Int
  overtimePayPerMinute Int
  totalBase            Int
  totalCommission      Int
  totalAdjustments     Int
  totalPayout          Int
  createdBy            String
  paidBy               String?
  paidAt               DateTime?
  externalRef          String?
  lines                HrPayrollLine[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([period, point])
  @@index([status, createdAt])
}

model HrPayrollLine {
  id                String       @id @default(cuid())
  run               HrPayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId             String
  staff             StaffUser    @relation(fields: [staffId], references: [id])
  staffId           String
  username          String
  plannedShifts     Int
  completedShifts   Int
  paidAbsenceShifts Int
  workedMinutes     Int
  lateMinutes       Int
  overtimeMinutes   Int
  revenue           Int
  sales             Int
  baseEarned        Int
  commission        Int
  lateDeduction     Int
  overtimePay       Int
  total             Int
  createdAt         DateTime     @default(now())

  @@unique([runId, staffId])
  @@index([staffId, createdAt])
}

model HrPayrollCommand {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  action         String
  runId          String?
  request        Json
  response       Json
  createdAt      DateTime @default(now())

  @@index([runId, createdAt])
}

enum StaffTaskStatus {
  open
  in_progress
  completed
  cancelled
}

enum StaffTaskPriority {
  low
  normal
  high
  urgent
}

model StaffTask {
  id          String            @id @default(cuid())
  title       String
  description String?
  status      StaffTaskStatus   @default(open)
  priority    StaffTaskPriority @default(normal)
  assigneeId  String
  assignee    StaffUser         @relation("StaffTaskAssignee", fields: [assigneeId], references: [id])
  createdById String
  createdBy   StaffUser         @relation("StaffTaskCreator", fields: [createdById], references: [id])
  dueAt       DateTime?
  relatedType String?
  relatedId   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  completedAt DateTime?

  @@index([assigneeId, status])
  @@index([dueAt])
}
