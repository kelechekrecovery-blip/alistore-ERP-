# AliStore production API env template.
# Copy to apps/api/.env.production and fill real values. Do not commit .env.production.

NODE_ENV="production"
PORT=4000
DATABASE_URL=""

# Auth. JWT_SECRET should be at least 32 chars. AUTH_OTP_DEV_ECHO must stay false
# in production.
JWT_SECRET=""
JWT_ACCESS_TTL="15m"
AUTH_OTP_DEV_ECHO="false"

# Online payment gateway. The current production adapter is a fail-visible port
# awaiting the selected provider's signed API contract; never put real values in Git.
PAYMENT_PROVIDER="production"
PAYMENT_API_URL=""
PAYMENT_MERCHANT_ID=""
PAYMENT_API_KEY=""
PAYMENT_WEBHOOK_SECRET=""
PAYMENT_PROVIDER_CERTIFIED="false"

# Background jobs.
RESERVATION_SWEEP_ENABLED="true"
OUTBOX_RELAY_ENABLED="true"

# AI provider. Set one of AI_PROVIDER_KEY or OPENROUTER_API_KEY.
AI_PROVIDER_KEY=""
OPENROUTER_API_KEY=""
AI_MODEL="openai/gpt-4o-mini"

# Telegram bot / Mini App.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_WEBHOOK_URL=""
TELEGRAM_AUTH_MAX_AGE_SECONDS="86400"
TELEGRAM_LOGIN_REDIRECT_URI=""

# WhatsApp Cloud API.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_API_URL="https://graph.facebook.com"
WHATSAPP_API_VERSION="v20.0"

# Apple Sign in.
APPLE_CLIENT_ID=""
APPLE_JWKS_URL="https://appleid.apple.com/auth/keys"
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
APPLE_REDIRECT_URI=""

# Campaign / transactional delivery. Use "channels" for channel-aware routing.
NOTIFICATION_TRANSPORT="channels"
NOVU_API_URL="https://api.novu.co"
NOVU_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_SECURE="false"
TELEGRAM_API_URL="https://api.telegram.org"

# Native mobile push / EAS.
EXPO_PUBLIC_EAS_PROJECT_ID=""
EXPO_TOKEN=""
EXPO_PUSH_API_URL="https://exp.host/--/api/v2/push/send"
EXPO_PUSH_ACCESS_TOKEN=""
FCM_SERVICE_ACCOUNT_KEY_PATH=""
APNS_KEY_ID=""
APNS_TEAM_ID=""

# Evidence Vault / media storage.
MEDIA_STORAGE="s3"
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_PUBLIC_BASE=""
MINIO_BUCKET=""
MINIO_ROOT_USER=""
MINIO_ROOT_PASSWORD=""

# Observability.
SENTRY_DSN=""

# Manual production marker. Set true only after the three hardware checks pass on site.
POS_HARDWARE_CERTIFIED="false"
