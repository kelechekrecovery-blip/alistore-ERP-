# AliStore production/staging API env template.
# Copy to apps/api/.env.production and fill real values. Do not commit .env.production.
# On Render most values are entered in the dashboard / env group, not in a file —
# see docs/OWNER-LAUNCH-CHECKLIST.md §2 and infra/render.staging.yaml.
# Coverage note: every env key read by apps/api/src is listed here or in
# apps/api/.env.example (dev-only keys like TEST_DATABASE_URL stay dev-only).

NODE_ENV="production"
PORT=4000
# Render: wired automatically by the Blueprint fromDatabase/fromService entries
# (Render dashboard → service → Environment). Manual only for self-hosted.
DATABASE_URL=""
DIRECT_DATABASE_URL=""
# Exact public HTTPS origins/hosts. Render: envVarGroups in infra/render.staging.yaml.
CORS_ORIGINS="https://ali.kg,https://admin.ali.kg"
ALLOWED_HOSTS="api.ali.kg"
PUBLIC_DEMO_MODE="true"

# Auth. JWT_SECRET should be at least 32 chars — Render Blueprint generateValue
# creates one; locally use `openssl rand -hex 32`. AUTH_OTP_DEV_ECHO must stay
# false in production (real codes go out via SMS).
JWT_SECRET=""
JWT_ACCESS_TTL="15m"
AUTH_OTP_DEV_ECHO="false"
# Guest order-tracking capability lifetime (seconds). Default 7 days; no external account needed.
GUEST_ORDER_CAPABILITY_TTL_SECONDS="604800"
# SMS/OTP. Три рабочих значения SMS_PROVIDER:
#   production      — боевой оператор (нужен договор + SMS_API_URL/KEY/SENDER_ID).
#   android_gateway — мост через Android-телефон с обычной SIM (SMS_GATEWAY_*).
#   disabled        — вход по SMS выключен; магазин работает гостевым checkout.
# SMS_PROVIDER_CERTIFIED флипается в true ТОЛЬКО после сертификации у боевого
# оператора — мост через телефон её не даёт (абонентская SIM не A2P-канал).
SMS_PROVIDER="disabled"
SMS_API_URL=""
SMS_API_KEY=""
SMS_SENDER_ID="AliStore"
SMS_PROVIDER_CERTIFIED="false"
# Мост через Android-телефон (capcom6/android-sms-gateway, режим Cloud). Где
# взять: приложение → включить Cloud Server → скопировать сгенерированные
# username/password; passphrase задаётся там же в настройках шифрования и должна
# СОВПАДАТЬ с SMS_GATEWAY_ENCRYPTION_PASSPHRASE (иначе телефон не расшифрует —
# код входа обязан уходить в публичное облако зашифрованным).
SMS_GATEWAY_URL="https://api.sms-gate.app/3rdparty/v1"
SMS_GATEWAY_USERNAME=""
SMS_GATEWAY_PASSWORD=""
SMS_GATEWAY_ENCRYPTION_PASSPHRASE=""

# Online payment gateway. Where to get — merchant contract with the chosen
# provider; dashboard issues PAYMENT_MERCHANT_ID / PAYMENT_API_KEY /
# PAYMENT_WEBHOOK_SECRET. The current production adapter is a fail-visible port
# awaiting the selected provider's signed API contract; never put real values in Git.
PAYMENT_PROVIDER="production"
PAYMENT_API_URL=""
PAYMENT_MERCHANT_ID=""
PAYMENT_API_KEY=""
PAYMENT_WEBHOOK_SECRET=""
PAYMENT_PROVIDER_CERTIFIED="false"
# Test-only escape hatch for the sandbox confirm endpoint. Keep unset/false in
# production; may be "true" on staging while PAYMENT_PROVIDER=sandbox there.
PAYMENTS_SANDBOX_CONFIRM_ENABLED="false"

# Background jobs. REDIS_URL on Render comes from the Key Value connection string
# (enable Internal Authentication so the URL carries a password — required by the
# production preflight). DEBT_REMINDERS_ENABLED turns on the durable debt sweep.
RESERVATION_SWEEP_ENABLED="true"
SERVICE_SLA_SWEEP_ENABLED="true"
OUTBOX_RELAY_ENABLED="true"
REFUND_RELAY_ENABLED="false"
DEBT_REMINDERS_ENABLED="true"
JOB_BACKEND="bullmq"
PROCESS_ROLE="api"
REDIS_URL="redis://:replace-with-secret@redis:6379"
REDIS_PASSWORD="replace-with-secret"
# Age (ms) after which a stuck provider_pending refund is parked for operator
# resolution. Default 24h; tune with finance, no external account needed.
REFUND_PROVIDER_PENDING_STALE_MS="86400000"

# Search acceleration. PostgreSQL remains the source of truth. Render: MEILI_HOST
# points at the internal meilisearch pserv, MEILI_API_KEY is the MEILI_MASTER_KEY
# generated by the Blueprint. SEARCH_ADMIN_TOKEN: self-generated random string.
MEILI_HOST="http://meilisearch:7700"
MEILI_API_KEY="replace-with-strong-search-key"
MEILI_PRODUCTS_INDEX="products"
SEARCH_ADMIN_TOKEN="replace-with-maintenance-secret"

# AI provider. Where to get — console.anthropic.com (ANTHROPIC_API_KEY) or
# openrouter.ai/keys (OPENROUTER_API_KEY / AI_PROVIDER_KEY). Set AI_PROVIDER to
# "anthropic", "openrouter" or "auto". Every AI feature keeps a keyless rule
# fallback, so empty values are safe.
AI_PROVIDER="auto"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
AI_FAST_MODEL="claude-haiku-4-5"
AI_PROVIDER_KEY=""
OPENROUTER_API_KEY=""
AI_MODEL="openai/gpt-4o-mini"
AI_ASSISTANT_TOOLS="false"

# Telegram bot / Mini App. Where to get — @BotFather (token), webhook URL is your
# public API address, webhook secret is a self-generated random string.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_WEBHOOK_URL=""
TELEGRAM_AUTH_MAX_AGE_SECONDS="86400"
TELEGRAM_LOGIN_REDIRECT_URI=""

# WhatsApp Cloud API. Where to get — Meta for Developers → WhatsApp app →
# access token, phone number id; verify token is a self-generated random string.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_API_URL="https://graph.facebook.com"
WHATSAPP_API_VERSION="v20.0"

# Apple Sign in. Where to get — developer.apple.com → Identifiers (App ID /
# Services ID = APPLE_CLIENT_ID) and Keys → Sign in with Apple key (.p8 content
# goes to APPLE_PRIVATE_KEY). Same Apple Developer account as §4 of the owner checklist.
APPLE_CLIENT_ID=""
APPLE_JWKS_URL="https://appleid.apple.com/auth/keys"
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
APPLE_REDIRECT_URI=""

# Campaign / transactional delivery. Use "channels" for channel-aware routing.
# Novu: novu.co project → API keys. SMTP: any transactional mail provider.
NOTIFICATION_TRANSPORT="channels"
NOVU_API_URL="https://api.novu.co"
NOVU_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_SECURE="false"
TELEGRAM_API_URL="https://api.telegram.org"

# Native mobile push / EAS. Where to get — Firebase console → Project settings →
# Service accounts (FCM_SERVICE_ACCOUNT_JSON content or a key file path mounted
# outside git); expo.dev project (EXPO_*); Apple Developer → Keys → APNs (.p8).
# See docs/OWNER-LAUNCH-CHECKLIST.md §5. Never commit the JSON/key files.
EXPO_PUBLIC_EAS_PROJECT_ID=""
EXPO_TOKEN=""
EXPO_PUSH_API_URL="https://exp.host/--/api/v2/push/send"
EXPO_PUSH_ACCESS_TOKEN=""
FCM_SERVICE_ACCOUNT_KEY_PATH=""
FCM_SERVICE_ACCOUNT_JSON=""
FCM_PROVIDER_CERTIFIED="false"
APNS_KEY_ID=""
APNS_TEAM_ID=""

# Evidence Vault / media storage. Where to get — Cloudflare dashboard → R2 →
# create EU-jurisdiction buckets + an S3 API token scoped to them:
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com, MINIO_ROOT_USER =
# token Access Key ID, MINIO_ROOT_PASSWORD = token Secret. MEDIA_STORAGE=local is
# the dev fallback (MEDIA_LOCAL_DIR/MEDIA_PUBLIC_BASE, see apps/api/.env.example).
# MEDIA_STORAGE=local is the dev fallback (see apps/api/.env.example); not used on Render.
# MEDIA_LOCAL_DIR="./uploads"
# MEDIA_PUBLIC_BASE="/uploads"
MEDIA_STORAGE="s3"
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_PUBLIC_BASE=""
EVIDENCE_SIGNED_URL_TTL_SECONDS="300"
EVIDENCE_PII_RETENTION_DAYS="365"
EVIDENCE_RETENTION_POLICY_VERSION="kg-privacy-v1"
MINIO_BUCKET=""
S3_BACKUP_BUCKET=""
MINIO_ROOT_USER=""
MINIO_ROOT_PASSWORD=""

# Store identity printed on informational receipts (not a fiscal/KKM claim).
# No external account — owner provides the real store facts.
STORE_NAME="AliStore"
STORE_ADDRESS=""
STORE_PHONE=""

# Observability. Sentry: sentry.io → org → project → Client Keys (DSN).
# METRICS_TOKEN: self-generated random bearer for /api/metrics.
SENTRY_DSN=""
METRICS_TOKEN=""
# Critical-alert channel (Telegram ops chat). Fail-silent while unset.
# Bot token from @BotFather; chat id via getUpdates or @userinfobot.
ALERT_TELEGRAM_BOT_TOKEN=""
ALERT_TELEGRAM_CHAT_ID=""
ALERT_TELEGRAM_API_URL="https://api.telegram.org"
ALERT_DEDUP_WINDOW_MS="300000"
ALERT_MAX_PER_WINDOW="10"

# Manual production marker. Set true only after the three hardware checks pass on site.
POS_HARDWARE_CERTIFIED="false"
