{
  "name": "@alistore/api",
  "version": "0.0.1",
  "private": true,
  "description": "AliStore backend — NestJS + Prisma (Event Ledger core)",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "start": "npm run start:prod",
    "start:dev": "NODE_PATH=./node_modules ts-node src/main.ts",
    "start:prod": "NODE_PATH=./node_modules node dist/main.js",
    "start:worker": "NODE_PATH=./node_modules PROCESS_ROLE=worker node dist/worker.js",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "preflight": "ts-node scripts/print-production-preflight.ts",
    "readiness": "ts-node scripts/print-readiness.ts",
    "test": "NODE_PATH=./node_modules jest",
    "test:watch": "NODE_PATH=./node_modules jest --watch"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.28",
    "@otplib/preset-default": "^12.0.1",
    "@otplib/preset-v11": "^12.0.1",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.63.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.80.2",
    "bwip-js": "^4.11.2",
    "casbin": "^5.51.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "helmet": "^8.3.0",
    "ioredis": "^5.10.1",
    "meilisearch": "^0.59.0",
    "nestjs-i18n": "^10.8.5",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "pg-boss": "^12.25.1",
    "receiptline": "^4.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "dotenv": "^16.4.7",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
