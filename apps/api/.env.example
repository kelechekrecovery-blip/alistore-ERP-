# Postgres connection (local dev). Copy to .env and adjust.
DATABASE_URL="postgresql://alistore@localhost:5432/alistore_dev?schema=public"
# Separate DB used by integration/acceptance tests (wiped between runs)
TEST_DATABASE_URL="postgresql://alistore@localhost:5432/alistore_test?schema=public"
PORT=4000

# Optional catalog search acceleration. Postgres remains the source of truth.
# Leave unset to use the built-in Postgres fallback.
# MEILI_HOST="http://localhost:7700"
# MEILI_API_KEY="dev-master-key"
# MEILI_PRODUCTS_INDEX="products"
# SEARCH_ADMIN_TOKEN="local-maintenance-token"

# Reservation-expiry sweep (invariant #7). Durable schedule via pg-boss on the
# same Postgres — no extra infra. Off by default; set to "true" to run the
# every-minute sweep that releases expired holds back to stock.
RESERVATION_SWEEP_ENABLED="false"

# Auth: phone+OTP login → JWT access + rotating refresh. Use a strong JWT_SECRET
# in production. AUTH_OTP_DEV_ECHO returns the OTP in the API response for local
# dev/tests only — it MUST stay false in production (real code goes out via SMS).
JWT_SECRET="dev-insecure-change-me"
JWT_ACCESS_TTL="15m"
AUTH_OTP_DEV_ECHO="true"

# Outbox relay: guaranteed notification/webhook delivery with retries, durable via
# pg-boss on the same Postgres. Off by default; set to "true" to run the relay.
OUTBOX_RELAY_ENABLED="false"

# --- v1 self-hosted infra (see infra/docker-compose.yml — NOT run locally here) ---
# Outbox delivery channel: "log" (default) or "novu". With "novu" + NOVU_API_KEY,
# the outbox ships via Novu's REST trigger API (Cloud or self-hosted instance).
NOTIFICATION_TRANSPORT="log"
NOVU_API_URL="https://api.novu.co"
NOVU_API_KEY=""
# MinIO (S3 object storage) — product photos, Evidence Vault.
MINIO_ROOT_USER="alistore"
MINIO_ROOT_PASSWORD="change-me-please"
MINIO_BUCKET="alistore"
# Metabase (owner BI) — password for its own app database.
METABASE_DB_PASS="change-me-please"

# Media (image upload → sharp WebP → storage). MEDIA_STORAGE: "local" (default)
# or "s3" (MinIO/S3). Local writes to MEDIA_LOCAL_DIR; serve it at MEDIA_PUBLIC_BASE.
MEDIA_STORAGE="local"
MEDIA_LOCAL_DIR="./uploads"
MEDIA_PUBLIC_BASE="/uploads"
# S3/MinIO storage (used when MEDIA_STORAGE=s3) — reuses the MINIO_* creds above.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
