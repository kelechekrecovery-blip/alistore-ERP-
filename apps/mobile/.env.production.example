# Copy to apps/mobile/.env.production for local strict release checks.
# Do not commit apps/mobile/.env.production.

EXPO_PUBLIC_API_BASE=https://api.ali.kg/api
EXPO_PUBLIC_EAS_PROJECT_ID=
EXPO_TOKEN=

# Option A: let EAS manage Apple credentials after `eas credentials`.
EXPO_APPLE_TEAM_ID=

# Option B: App Store Connect API key for automation.
EXPO_ASC_API_KEY_ID=
EXPO_ASC_API_KEY_ISSUER_ID=
EXPO_ASC_API_KEY_PATH=./AuthKey_EXAMPLE.p8
# Alternative to a local .p8 file:
# EXPO_ASC_API_KEY_P8_BASE64=

# Google Play submit credentials. Prefer a local ignored JSON file for local runs
# or a base64 secret in CI/EAS workflows.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json
# EXPO_ANDROID_SERVICE_ACCOUNT_KEY_BASE64=
