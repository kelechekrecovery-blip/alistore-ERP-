{
  "name": "@alistore/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "AliStore native customer, staff, and POS app built with Expo React Native",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "expo:config": "expo config --json",
    "store:assets": "node scripts/generate-store-assets.mjs",
    "store:preflight": "node scripts/store-preflight.mjs",
    "store:preflight:strict": "node scripts/store-preflight.mjs --strict",
    "store:preflight:production": "node scripts/store-preflight.mjs --strict --store-env-file .env.production",
    "eas:build": "npx eas-cli@20.5.1 build --profile production",
    "eas:build:ios": "npx eas-cli@20.5.1 build -p ios --profile production",
    "eas:build:android": "npx eas-cli@20.5.1 build -p android --profile production",
    "eas:submit:ios": "npx eas-cli@20.5.1 submit -p ios --latest --profile production",
    "eas:submit:android": "npx eas-cli@20.5.1 submit -p android --latest --profile production"
  },
  "expo": {
    "autolinking": {
      "legacy_shallowReactNativeLinking": true
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~57.0.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
