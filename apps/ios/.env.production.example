# Copy to apps/ios/.env.production and fill real protected values.
# Never commit apps/ios/.env.production.

ALISTORE_API_BASE_URL=https://api.ali.kg/api
DEVELOPMENT_TEAM=XXXXXXXXXX
ASC_API_KEY_PATH=/Users/alistore/.appstoreconnect/private_keys/AuthKey_KEYID.p8
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Set to true only when the release machine is signed in to the protected Apple
# Developer account and Xcode is allowed to create/download signing profiles.
IOS_ALLOW_PROVISIONING_UPDATE=false
