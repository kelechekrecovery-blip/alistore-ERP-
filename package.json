{
  "name": "alistore-erp",
  "version": "0.0.1",
  "private": true,
  "description": "AliStore — операционная система для розничной торговли электроникой (КР)",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "api": "npm run start:dev -w @alistore/api",
    "api:build": "npm run build -w @alistore/api",
    "api:test": "npm run test -w @alistore/api",
    "e2e": "playwright test",
    "mvp:verify": "node scripts/mvp-verify.mjs",
    "web": "npm run dev -w @alistore/web",
    "db:migrate": "npm run db:migrate -w @alistore/api",
    "db:seed": "npm run db:seed -w @alistore/api",
    "db:studio": "npm run db:studio -w @alistore/api"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
